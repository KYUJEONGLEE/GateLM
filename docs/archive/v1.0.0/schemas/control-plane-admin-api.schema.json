{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/docs/archive/v1.0.0/schemas/control-plane-admin-api.schema.json",
  "title": "GateLM v1 Control Plane Admin API Route Catalog Fixture",
  "description": "Route catalog contract for Web Console and Control Plane Admin API implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureName",
    "fixtureVersion",
    "owner",
    "producer",
    "consumers",
    "sourceOfTruth",
    "notes",
    "adminApi"
  ],
  "properties": {
    "fixtureName": { "$ref": "#/$defs/nonEmptyString" },
    "fixtureVersion": { "$ref": "#/$defs/nonEmptyString" },
    "owner": { "$ref": "#/$defs/nonEmptyString" },
    "producer": { "$ref": "#/$defs/nonEmptyString" },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "sourceOfTruth": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "adminApi": { "$ref": "#/$defs/adminApi" }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "adminApi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "basePath", "auth", "commonErrorResponse", "endpoints"],
      "properties": {
        "schemaVersion": { "const": "gatelm.control-plane-admin-api.v1" },
        "basePath": { "const": "/admin/v1" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "mode"],
          "properties": {
            "required": { "type": "boolean" },
            "mode": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "commonErrorResponse": {
          "type": "object",
          "additionalProperties": false,
          "required": ["shape", "codes"],
          "properties": {
            "shape": {
              "type": "object",
              "additionalProperties": false,
              "required": ["error"],
              "properties": {
                "error": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["message", "code", "requestId"],
                  "properties": {
                    "message": { "$ref": "#/$defs/nonEmptyString" },
                    "code": { "$ref": "#/$defs/nonEmptyString" },
                    "requestId": { "$ref": "#/$defs/nonEmptyString" }
                  }
                }
              }
            },
            "codes": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" },
              "uniqueItems": true
            }
          }
        },
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/endpoint" }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operationId",
        "method",
        "path",
        "owner",
        "consumer",
        "requestContract",
        "responseContract",
        "successStatus",
        "authRequired",
        "idempotency",
        "notes"
      ],
      "properties": {
        "operationId": { "$ref": "#/$defs/nonEmptyString" },
        "method": { "enum": ["GET", "POST", "PATCH", "DELETE"] },
        "path": {
          "type": "string",
          "pattern": "^/admin/v1/"
        },
        "owner": { "const": "control-plane-runtime-policy" },
        "consumer": {
          "enum": [
            "product-experience-demo",
            "gateway-data-plane-governance",
            "observability-performance"
          ]
        },
        "requestContract": { "$ref": "#/$defs/nonEmptyString" },
        "responseContract": { "$ref": "#/$defs/nonEmptyString" },
        "successStatus": {
          "type": "integer",
          "minimum": 200,
          "maximum": 204
        },
        "authRequired": { "type": "boolean" },
        "idempotency": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    }
  }
}
