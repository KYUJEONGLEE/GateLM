{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "GateLM Tenant Chat Admin Runtime API",
    "version": "tenant-chat/v1",
    "description": "Tenant-admin setup and immutable RuntimeSnapshot activation contract. Credential material and RuntimeSnapshot bodies are never returned."
  },
  "security": [{ "adminSession": [] }],
  "paths": {
    "/admin/v1/tenants/{tenantId}/tenant-chat/runtime": {
      "parameters": [
        {
          "name": "tenantId",
          "in": "path",
          "required": true,
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "getTenantChatAdminRuntimeSetup",
        "summary": "Read Tenant Chat Provider, model pricing support and readiness",
        "responses": {
          "200": {
            "description": "Safe administrator setup model.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SetupEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/AuthenticationRequired" },
          "403": { "$ref": "#/components/responses/TenantScopeForbidden" }
        }
      },
      "put": {
        "operationId": "activateTenantChatAdminRuntime",
        "summary": "Publish Tenant Chat routing, cache and safety policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ActivateRuntimeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Existing equivalent snapshot or newly published active snapshot.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SetupEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/AuthenticationRequired" },
          "403": { "$ref": "#/components/responses/TenantScopeForbidden" },
          "404": { "$ref": "#/components/responses/ProviderUnavailable" },
          "409": { "$ref": "#/components/responses/PublishConflict" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "adminSession": {
        "type": "apiKey",
        "in": "cookie",
        "name": "gatelm_session",
        "description": "Full Control Plane admin session. The exact cookie name is implementation-owned and never exposed to application JavaScript."
      }
    },
    "schemas": {
      "ActivateRuntimeRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["routingMode", "manualModelRef", "routes", "cachePolicy", "safetyPolicy"],
        "properties": {
          "routingMode": { "type": "string", "enum": ["auto", "manual"] },
          "manualModelRef": { "$ref": "#/components/schemas/ModelKey" },
          "routes": { "$ref": "#/components/schemas/RoutingMatrix" },
          "cachePolicy": { "$ref": "#/components/schemas/CachePolicy" },
          "safetyPolicy": { "$ref": "#/components/schemas/SafetyPolicy" },
          "cacheEnabled": {
            "type": "boolean",
            "description": "Compatibility toggle. Current authoring clients use cachePolicy."
          }
        }
      },
      "CachePolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "ttlSeconds", "maxEntriesPerUser"],
        "properties": {
          "enabled": { "type": "boolean" },
          "ttlSeconds": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
          "maxEntriesPerUser": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
        }
      },
      "SafetyPolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["detectorSet"],
        "properties": {
          "detectorSet": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "uniqueItems": true,
            "items": { "$ref": "#/components/schemas/SafetyDetector" }
          }
        }
      },
      "SafetyDetector": {
        "type": "object",
        "additionalProperties": false,
        "required": ["detectorType", "action"],
        "properties": {
          "detectorType": {
            "type": "string",
            "enum": ["email", "phone_number", "postal_address", "person_name", "organization_name", "resident_registration_number", "api_key", "authorization_header", "jwt", "private_key"]
          },
          "action": { "type": "string", "enum": ["allow", "redact", "block"] }
        }
      },
      "ModelKey": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,199}$"
      },
      "RoutingCell": {
        "type": "object",
        "additionalProperties": false,
        "required": ["modelRefs"],
        "properties": {
          "modelRefs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": { "$ref": "#/components/schemas/ModelKey" }
          }
        }
      },
      "RoutingDifficulty": {
        "type": "object",
        "additionalProperties": false,
        "required": ["simple", "complex"],
        "properties": {
          "simple": { "$ref": "#/components/schemas/RoutingCell" },
          "complex": { "$ref": "#/components/schemas/RoutingCell" }
        }
      },
      "RoutingMatrix": {
        "type": "object",
        "additionalProperties": false,
        "required": ["general", "code", "translation", "summarization", "reasoning"],
        "properties": {
          "general": { "$ref": "#/components/schemas/RoutingDifficulty" },
          "code": { "$ref": "#/components/schemas/RoutingDifficulty" },
          "translation": { "$ref": "#/components/schemas/RoutingDifficulty" },
          "summarization": { "$ref": "#/components/schemas/RoutingDifficulty" },
          "reasoning": { "$ref": "#/components/schemas/RoutingDifficulty" }
        }
      },
      "SetupEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data"],
        "properties": { "data": { "$ref": "#/components/schemas/RuntimeSetup" } }
      },
      "RuntimeSetup": {
        "type": "object",
        "additionalProperties": false,
        "required": ["readiness", "providers", "activeSnapshot"],
        "properties": {
          "readiness": {
            "type": "string",
            "enum": ["needs_provider", "needs_model", "needs_activation", "ready", "degraded"]
          },
          "providers": {
            "type": "array",
            "maxItems": 100,
            "items": { "$ref": "#/components/schemas/ProviderCandidate" }
          },
          "activeSnapshot": {
            "oneOf": [
              { "$ref": "#/components/schemas/ActiveSnapshot" },
              { "type": "null" }
            ]
          }
        }
      },
      "ProviderCandidate": {
        "type": "object",
        "additionalProperties": false,
        "required": ["providerConnectionId", "providerKey", "providerFamily", "displayName", "models"],
        "properties": {
          "providerConnectionId": { "type": "string", "format": "uuid" },
          "providerKey": { "type": "string", "minLength": 1, "maxLength": 64 },
          "providerFamily": { "type": "string", "minLength": 1, "maxLength": 64 },
          "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
          "models": {
            "type": "array",
            "maxItems": 200,
            "items": { "$ref": "#/components/schemas/ModelCandidate" }
          }
        }
      },
      "ModelCandidate": {
        "type": "object",
        "additionalProperties": false,
        "required": ["modelRef", "modelKey", "activationStatus", "pricingStatus", "pricing"],
        "properties": {
          "modelRef": { "$ref": "#/components/schemas/ModelKey" },
          "modelKey": { "$ref": "#/components/schemas/ModelKey" },
          "activationStatus": { "const": "available" },
          "pricingStatus": { "type": "string", "enum": ["available", "unavailable"] },
          "pricing": {
            "oneOf": [
              { "$ref": "#/components/schemas/ModelPricing" },
              { "type": "null" }
            ]
          }
        }
      },
      "ModelPricing": {
        "type": "object",
        "additionalProperties": false,
        "required": ["inputMicroUsdPerMillionTokens", "outputMicroUsdPerMillionTokens"],
        "properties": {
          "inputMicroUsdPerMillionTokens": { "type": "integer", "minimum": 0 },
          "outputMicroUsdPerMillionTokens": { "type": "integer", "minimum": 0 },
          "cacheReadInputMicroUsdPerMillionTokens": { "type": "integer", "minimum": 0 }
        }
      },
      "ActiveSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "required": ["snapshotId", "version", "digest", "policyVersion", "pricingVersion", "providerConnectionId", "modelKey", "publishedAt", "pricingStatus", "routingMode", "manualModelRef", "routes", "cachePolicy", "safetyPolicy", "cacheEnabled"],
        "properties": {
          "snapshotId": { "type": "string", "minLength": 1, "maxLength": 128 },
          "version": { "type": "integer", "minimum": 1 },
          "digest": { "type": "string", "pattern": "^sha256:[A-Za-z0-9_-]{43}$" },
          "policyVersion": { "type": "integer", "minimum": 1 },
          "pricingVersion": { "type": "integer", "minimum": 1 },
          "providerConnectionId": { "type": "string", "format": "uuid" },
          "modelKey": { "$ref": "#/components/schemas/ModelKey" },
          "routingMode": { "type": "string", "enum": ["auto", "manual"] },
          "manualModelRef": { "$ref": "#/components/schemas/ModelKey" },
          "routes": { "$ref": "#/components/schemas/RoutingMatrix" },
          "cachePolicy": { "$ref": "#/components/schemas/CachePolicy" },
          "safetyPolicy": { "$ref": "#/components/schemas/SafetyPolicy" },
          "cacheEnabled": { "type": "boolean" },
          "publishedAt": { "type": "string", "format": "date-time" },
          "pricingStatus": { "type": "string", "enum": ["current", "update_available", "unavailable"] }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "statusCode": { "type": "integer" },
          "message": { "type": ["string", "array"] },
          "error": { "type": "string" }
        }
      }
    },
    "responses": {
      "ValidationError": { "description": "Invalid tenant ID, body or unconfigured model.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorEnvelope" } } } },
      "AuthenticationRequired": { "description": "Full admin session is required.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorEnvelope" } } } },
      "TenantScopeForbidden": { "description": "The admin is outside this tenant scope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorEnvelope" } } } },
      "ProviderUnavailable": { "description": "The tenant-level ACTIVE Provider connection is unavailable.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorEnvelope" } } } },
      "PublishConflict": { "description": "Concurrent monotonic publication did not converge.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorEnvelope" } } } }
    }
  }
}
