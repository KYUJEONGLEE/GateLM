{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "GateLM Tenant Chat Private Gateway API",
    "version": "tenant-chat/v1",
    "description": "Private service-to-service contract. These paths must not be registered on the public /v1 listener or published as a host port."
  },
  "servers": [
    {
      "url": "http://gateway-core:8081",
      "description": "Compose private service network only"
    }
  ],
  "security": [
    { "workloadJwt": [] }
  ],
  "paths": {
    "/internal/v1/tenant-chat/admissions": {
      "post": {
        "operationId": "createTenantChatAdmission",
        "summary": "Create a content-free request-rate and concurrency admission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdmissionRequest" },
              "examples": {
                "employeeAdmission": { "$ref": "#/components/examples/AdmissionRequestExample" }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "A new 30-second admission was created.",
            "headers": {
              "Idempotency-Replayed": { "$ref": "#/components/headers/IdempotencyReplayed" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdmissionResponse" },
                "examples": { "created": { "$ref": "#/components/examples/AdmissionResponseExample" } }
              }
            }
          },
          "200": {
            "description": "Same key and binding replayed the existing admission; no extra slot was consumed.",
            "headers": {
              "Idempotency-Replayed": { "$ref": "#/components/headers/IdempotencyReplayed" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdmissionResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/TokenInvalid" },
          "409": { "$ref": "#/components/responses/IdempotencyConflict" },
          "429": { "$ref": "#/components/responses/AdmissionRateLimited" },
          "503": { "$ref": "#/components/responses/GuardUnavailable" }
        }
      }
    },
    "/internal/v1/tenant-chat/admissions/{admissionId}/cancel": {
      "post": {
        "operationId": "cancelTenantChatAdmission",
        "summary": "Idempotently cancel an unconsumed admission",
        "parameters": [
          {
            "name": "admissionId",
            "in": "path",
            "required": true,
            "schema": { "$ref": "#/components/schemas/OpaqueId" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CancelRequest" },
              "examples": { "cancel": { "$ref": "#/components/examples/CancelRequestExample" } }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cancelled now or replayed an earlier successful cancel.",
            "headers": {
              "Idempotency-Replayed": { "$ref": "#/components/headers/IdempotencyReplayed" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancelResponse" },
                "examples": { "cancelled": { "$ref": "#/components/examples/CancelResponseExample" } }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/TokenInvalid" },
          "409": { "$ref": "#/components/responses/AdmissionExpiredOrConflict" },
          "503": { "$ref": "#/components/responses/GuardUnavailable" }
        }
      }
    },
    "/internal/v1/tenant-chat/completions": {
      "post": {
        "operationId": "completeTenantChatTurn",
        "summary": "Consume an admission and stream the policy/provider result",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompletionRequest" },
              "examples": { "streaming": { "$ref": "#/components/examples/CompletionRequestExample" } }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New execution, in-flight attach, or terminal replay. Each SSE data object follows completion-sse-event.schema.json.",
            "headers": {
              "Idempotency-Replayed": { "$ref": "#/components/headers/IdempotencyReplayed" },
              "Cache-Control": {
                "required": true,
                "schema": { "type": "string", "const": "no-store" }
              }
            },
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" },
                "x-sse-data-schema": "../schemas/completion-sse-event.schema.json",
                "examples": {
                  "final": {
                    "value": "id: request_fixture_001:5\nevent: tenant_chat.final\ndata: {\"type\":\"tenant_chat.final\",\"schemaVersion\":1,\"requestId\":\"request_fixture_001\",\"turnId\":\"turn_fixture_001\",\"sequence\":5,\"terminalOutcome\":\"succeeded\",\"effectiveModelKey\":\"model_standard_001\",\"usage\":{\"inputTokens\":640,\"outputTokens\":320,\"totalTokens\":960,\"usageQuality\":\"confirmed\"},\"quotaState\":\"normal\",\"budgetState\":\"warning\",\"cacheOutcome\":\"miss\",\"replayed\":false}\n\n"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/TokenInvalid" },
          "403": { "$ref": "#/components/responses/LimitDenied" },
          "409": { "$ref": "#/components/responses/CompletionConflict" },
          "429": { "$ref": "#/components/responses/AdmissionRateLimited" },
          "502": { "$ref": "#/components/responses/ProviderFailed" },
          "503": { "$ref": "#/components/responses/RuntimeOrGuardUnavailable" },
          "504": { "$ref": "#/components/responses/ProviderTimeout" }
        }
      }
    },
    "/internal/v1/tenant-chat/usage-receipts": {
      "post": {
        "operationId": "recordTenantChatUsageReceipt",
        "summary": "Record exactly-once late Provider usage for an existing attempt",
        "security": [{ "usageReceiptBearer": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UsageReceiptRequest" } } }
        },
        "responses": {
          "200": { "description": "Receipt applied or replayed.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UsageReceiptResponse" } } } },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/TokenInvalid" },
          "409": { "$ref": "#/components/responses/IdempotencyConflict" },
          "503": { "$ref": "#/components/responses/GuardUnavailable" }
        }
      }
    },
    "/internal/v1/rag/embeddings": {
      "post": {
        "operationId": "createPrivateRagEmbeddings",
        "summary": "Create fixed-profile RAG embeddings without exposing the provider credential",
        "description": "Private-listener-only route. Tenant identity, request identity, operation identity, caller identity, and allowed purpose come from the verified RAG workload JWT; tenantId, provider, model, dimensions, credential, base URL, and cache controls are forbidden request fields.",
        "security": [{ "ragEmbeddingWorkloadJwt": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "../schemas/rag-embedding-request.schema.json" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Embeddings are returned in the same order as inputs with bounded provider usage metadata.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RagEmbeddingResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/RagEmbeddingInvalidRequest" },
          "401": { "$ref": "#/components/responses/RagEmbeddingTokenInvalid" },
          "429": { "$ref": "#/components/responses/RagEmbeddingRateLimited" },
          "502": { "$ref": "#/components/responses/RagEmbeddingProviderFailed" },
          "503": { "$ref": "#/components/responses/RagEmbeddingUnavailable" },
          "504": { "$ref": "#/components/responses/RagEmbeddingProviderTimeout" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "workloadJwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "gatelm-workload+jwt",
        "description": "Ed25519 JWT defined by workload-jwt-claims.schema.json"
      },
      "usageReceiptBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "opaque-service-token",
        "description": "Dedicated token loaded from TENANT_CHAT_USAGE_RECEIPT_TOKEN_FILE; never accepted by workload-JWT routes."
      },
      "ragEmbeddingWorkloadJwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "gatelm-rag-workload+jwt",
        "description": "Caller-key-bound Ed25519 JWT defined by rag-embedding-workload-jwt-claims.schema.json. Chat API keys authorize RAG_QUERY only; Control Plane Worker keys authorize RAG_INGESTION only."
      }
    },
    "headers": {
      "IdempotencyReplayed": {
        "required": true,
        "schema": { "type": "boolean" },
        "description": "true only when an existing execution result or stream was reused"
      }
    },
    "schemas": {
      "OpaqueId": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "AdmissionContext": {
        "allOf": [
          { "$ref": "../schemas/gateway-request-context.schema.json" },
          {
            "type": "object",
            "properties": { "phase": { "const": "admission" } }
          }
        ]
      },
      "CancelContext": {
        "allOf": [
          { "$ref": "../schemas/gateway-request-context.schema.json" },
          {
            "type": "object",
            "properties": { "phase": { "const": "cancel" } }
          }
        ]
      },
      "CompletionContext": {
        "allOf": [
          { "$ref": "../schemas/gateway-request-context.schema.json" },
          {
            "type": "object",
            "properties": { "phase": { "const": "completion" } }
          }
        ]
      },
      "AdmissionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["context"],
        "properties": { "context": { "$ref": "#/components/schemas/AdmissionContext" } }
      },
      "CancelRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["context"],
        "properties": { "context": { "$ref": "#/components/schemas/CancelContext" } }
      },
      "CompletionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["context", "input"],
        "properties": {
          "context": { "$ref": "#/components/schemas/CompletionContext" },
          "input": { "$ref": "#/components/schemas/CompletionInput" }
        }
      },
      "CompletionInput": {
        "type": "object",
        "additionalProperties": false,
        "required": ["messages", "stream"],
        "properties": {
          "messages": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "items": { "$ref": "#/components/schemas/EphemeralMessage" }
          },
          "stream": { "const": true }
        }
      },
      "UsageReceiptRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId", "attemptNo", "providerId", "inputTokens", "outputTokens", "cacheReadInputTokens"],
        "properties": {
          "requestId": { "$ref": "#/components/schemas/OpaqueId" },
          "attemptNo": { "type": "integer", "minimum": 1, "maximum": 4 },
          "providerId": { "$ref": "#/components/schemas/OpaqueId" },
          "inputTokens": { "type": "integer", "minimum": 0 },
          "outputTokens": { "type": "integer", "minimum": 0 },
          "cacheReadInputTokens": { "type": "integer", "minimum": 0 }
        }
      },
      "UsageReceiptResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId", "attemptNo", "state", "replayed"],
        "properties": {
          "requestId": { "$ref": "#/components/schemas/OpaqueId" },
          "attemptNo": { "type": "integer", "minimum": 1, "maximum": 4 },
          "state": { "type": "string", "enum": ["pending", "settled", "unconfirmed"] },
          "replayed": { "type": "boolean" }
        }
      },
      "EphemeralMessage": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "allOf": [
          {
            "if": {
              "required": ["purpose"],
              "properties": { "purpose": { "const": "rag_context" } }
            },
            "then": {
              "properties": {
                "role": { "const": "system" },
                "content": { "maxLength": 65536 }
              }
            },
            "else": { "properties": { "content": { "maxLength": 20000 } } }
          }
        ],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "purpose": {
            "type": "string",
            "enum": ["rag_context"],
            "description": "Optional private marker allowed only with role=system. It is provider- and budget-bound but excluded from routing classification."
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65536,
            "description": "Ephemeral provider-bound content. Non-RAG messages remain capped at 20000 characters; only the private system rag_context marker may use up to 65536. Never log, persist in Gateway tables, or include in metrics."
          }
        }
      },
      "AdmissionResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["admissionId", "requestId", "state", "expiresAt", "replayed"],
        "properties": {
          "admissionId": { "$ref": "#/components/schemas/OpaqueId" },
          "requestId": { "$ref": "#/components/schemas/OpaqueId" },
          "state": { "const": "active" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "replayed": { "type": "boolean" }
        }
      },
      "CancelResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["admissionId", "requestId", "state", "slotReleased", "replayed"],
        "properties": {
          "admissionId": { "$ref": "#/components/schemas/OpaqueId" },
          "requestId": { "$ref": "#/components/schemas/OpaqueId" },
          "state": { "const": "cancelled" },
          "slotReleased": { "type": "boolean" },
          "replayed": { "type": "boolean" }
        }
      },
      "RagEmbeddingResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId", "purpose", "provider", "model", "dimensions", "profileVersion", "embeddings", "usage"],
        "properties": {
          "requestId": { "$ref": "#/components/schemas/OpaqueId" },
          "purpose": { "type": "string", "enum": ["RAG_INGESTION", "RAG_QUERY"] },
          "provider": { "type": "string", "const": "openai" },
          "model": { "type": "string", "const": "text-embedding-3-large" },
          "dimensions": { "type": "integer", "const": 1536 },
          "profileVersion": { "type": "integer", "const": 1 },
          "embeddings": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": {
              "type": "array",
              "minItems": 1536,
              "maxItems": 1536,
              "items": { "type": "number" }
            }
          },
          "usage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["inputCount", "promptTokens", "totalTokens"],
            "properties": {
              "inputCount": { "type": "integer", "minimum": 1, "maximum": 128 },
              "promptTokens": { "type": "integer", "minimum": 1, "maximum": 300000 },
              "totalTokens": { "type": "integer", "minimum": 1, "maximum": 300000 }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "CHAT_INVALID_REQUEST",
              "CHAT_SCOPE_FIELD_FORBIDDEN",
              "CHAT_TOKEN_INVALID",
              "CHAT_USER_DISABLED",
              "CHAT_TENANT_DISABLED",
              "CHAT_MEMBERSHIP_DISABLED",
              "CHAT_EMPLOYEE_DISABLED",
              "CHAT_QUOTA_HARD_LIMIT",
              "CHAT_BUDGET_HARD_LIMIT",
              "CHAT_POLICY_ACK_REQUIRED",
              "CHAT_IDEMPOTENCY_CONFLICT",
              "CHAT_ADMISSION_EXPIRED",
              "CHAT_RATE_LIMITED",
              "CHAT_CONCURRENCY_LIMITED",
              "CHAT_SAFETY_BLOCKED",
              "CHAT_PROVIDER_FAILED",
              "CHAT_RUNTIME_UNAVAILABLE",
              "CHAT_USAGE_GUARD_UNAVAILABLE",
              "CHAT_NO_ELIGIBLE_ROUTE",
              "CHAT_PROVIDER_TIMEOUT",
              "RAG_EMBEDDING_INVALID_REQUEST",
              "RAG_EMBEDDING_TOKEN_INVALID",
              "RAG_EMBEDDING_RATE_LIMITED",
              "RAG_EMBEDDING_PROVIDER_FAILED",
              "RAG_EMBEDDING_UNAVAILABLE",
              "RAG_EMBEDDING_PROVIDER_TIMEOUT"
            ]
          },
          "message": { "type": "string", "minLength": 1, "maxLength": 256 },
          "retryAfterSeconds": { "type": "integer", "minimum": 1, "maximum": 300 }
        }
      }
    },
    "responses": {
      "InvalidRequest": {
        "description": "400 CHAT_INVALID_REQUEST or CHAT_SCOPE_FIELD_FORBIDDEN",
        "x-error-codes": ["CHAT_INVALID_REQUEST", "CHAT_SCOPE_FIELD_FORBIDDEN"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "TokenInvalid": {
        "description": "401 CHAT_TOKEN_INVALID",
        "x-error-codes": ["CHAT_TOKEN_INVALID"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "LimitDenied": {
        "description": "403 CHAT_SAFETY_BLOCKED, CHAT_QUOTA_HARD_LIMIT, or CHAT_BUDGET_HARD_LIMIT. User and Employee entitlement errors are owned by Chat API, not this private Gateway API.",
        "x-error-codes": ["CHAT_SAFETY_BLOCKED", "CHAT_QUOTA_HARD_LIMIT", "CHAT_BUDGET_HARD_LIMIT"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "IdempotencyConflict": {
        "description": "409 CHAT_IDEMPOTENCY_CONFLICT",
        "x-error-codes": ["CHAT_IDEMPOTENCY_CONFLICT"],
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "code": "CHAT_IDEMPOTENCY_CONFLICT", "message": "The idempotency key is bound to a different request." }
          }
        }
      },
      "AdmissionExpiredOrConflict": {
        "description": "409 CHAT_ADMISSION_EXPIRED or CHAT_IDEMPOTENCY_CONFLICT",
        "x-error-codes": ["CHAT_ADMISSION_EXPIRED", "CHAT_IDEMPOTENCY_CONFLICT"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "CompletionConflict": {
        "description": "409 admission, idempotency, or policy acknowledgement conflict",
        "x-error-codes": ["CHAT_ADMISSION_EXPIRED", "CHAT_IDEMPOTENCY_CONFLICT", "CHAT_POLICY_ACK_REQUIRED"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "AdmissionRateLimited": {
        "description": "429 CHAT_RATE_LIMITED or CHAT_CONCURRENCY_LIMITED",
        "x-error-codes": ["CHAT_RATE_LIMITED", "CHAT_CONCURRENCY_LIMITED"],
        "headers": {
          "Retry-After": { "schema": { "type": "integer", "minimum": 1, "maximum": 300 } }
        },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "GuardUnavailable": {
        "description": "503 CHAT_USAGE_GUARD_UNAVAILABLE",
        "x-error-codes": ["CHAT_USAGE_GUARD_UNAVAILABLE"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RuntimeOrGuardUnavailable": {
        "description": "503 CHAT_RUNTIME_UNAVAILABLE, CHAT_USAGE_GUARD_UNAVAILABLE, or CHAT_NO_ELIGIBLE_ROUTE",
        "x-error-codes": ["CHAT_RUNTIME_UNAVAILABLE", "CHAT_USAGE_GUARD_UNAVAILABLE", "CHAT_NO_ELIGIBLE_ROUTE"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "ProviderFailed": {
        "description": "502 CHAT_PROVIDER_FAILED",
        "x-error-codes": ["CHAT_PROVIDER_FAILED"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "ProviderTimeout": {
        "description": "504 CHAT_PROVIDER_TIMEOUT",
        "x-error-codes": ["CHAT_PROVIDER_TIMEOUT"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingInvalidRequest": {
        "description": "400 RAG_EMBEDDING_INVALID_REQUEST",
        "x-error-codes": ["RAG_EMBEDDING_INVALID_REQUEST"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingTokenInvalid": {
        "description": "401 RAG_EMBEDDING_TOKEN_INVALID",
        "x-error-codes": ["RAG_EMBEDDING_TOKEN_INVALID"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingRateLimited": {
        "description": "429 RAG_EMBEDDING_RATE_LIMITED after bounded provider retries are exhausted",
        "x-error-codes": ["RAG_EMBEDDING_RATE_LIMITED"],
        "headers": {
          "Retry-After": { "schema": { "type": "integer", "minimum": 1, "maximum": 300 } }
        },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingProviderFailed": {
        "description": "502 RAG_EMBEDDING_PROVIDER_FAILED",
        "x-error-codes": ["RAG_EMBEDDING_PROVIDER_FAILED"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingUnavailable": {
        "description": "503 RAG_EMBEDDING_UNAVAILABLE for replay-guard, credential, or service unavailability",
        "x-error-codes": ["RAG_EMBEDDING_UNAVAILABLE"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "RagEmbeddingProviderTimeout": {
        "description": "504 RAG_EMBEDDING_PROVIDER_TIMEOUT",
        "x-error-codes": ["RAG_EMBEDDING_PROVIDER_TIMEOUT"],
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    },
    "examples": {
      "AdmissionRequestExample": {
        "value": {
          "context": {
            "surface": "tenant_chat",
            "phase": "admission",
            "requestId": "request_fixture_001",
            "turnId": "turn_fixture_001",
            "idempotencyKey": "turn_fixture_001_attempt_1",
            "executionScope": {
              "kind": "tenant_chat",
              "tenantId": "tenant_fixture_001",
              "actor": {
                "userId": "user_fixture_001",
                "actorKind": "employee",
                "employeeId": "employee_fixture_001"
              },
              "quotaScope": { "type": "user", "id": "user_fixture_001" },
              "budgetScope": { "type": "tenant", "id": "tenant_fixture_001" }
            },
            "snapshot": {
              "version": 12,
              "digest": "sha256:QTJXSkcD9dvUyD2iz63k6npQETJmbS9IvHe9Bx8xx9M",
              "policyVersion": 8,
              "employeeNoticeVersion": 3,
              "pricingVersion": 5
            },
            "bindingDigest": "hmac-sha256:BMVPZ2qQx-4Ewex5FGnDXGpjERAhSn7WF_3BfkNuG6M"
          }
        }
      },
