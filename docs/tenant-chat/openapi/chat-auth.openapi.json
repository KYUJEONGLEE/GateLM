{
  "openapi": "3.1.0",
  "info": {
    "title": "GateLM Tenant Chat Auth API",
    "version": "tenant-chat/v1",
    "description": "Browser BFF, private Chat API, and private Control Plane identity boundary for Tenant Chat authentication."
  },
  "paths": {
    "/api/tenant-chat/auth/login": {
      "post": {
        "summary": "Authenticate an existing account through the same-origin Chat Web BFF",
        "requestBody": { "$ref": "#/components/requestBodies/PasswordLogin" },
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/password-reset/request": {
      "post": {
        "summary": "Request a generic password reset response without exposing account existence",
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetRequest" },
        "responses": {
          "202": { "$ref": "#/components/responses/PasswordResetAccepted" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/password-reset/confirm": {
      "post": {
        "summary": "Consume a one-time reset token and revoke all existing sessions",
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetConfirm" },
        "responses": {
          "200": { "$ref": "#/components/responses/PasswordResetResult" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/password/change": {
      "post": {
        "summary": "Change the active local account password and require a fresh login",
        "requestBody": { "$ref": "#/components/requestBodies/PasswordChange" },
        "responses": {
          "200": { "$ref": "#/components/responses/PasswordChangeResult" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/refresh": {
      "post": {
        "summary": "Rotate the refresh token and issue a new access JWT",
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "409": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/logout": {
      "post": {
        "summary": "Revoke the current Chat session and clear Chat cookies",
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/session": {
      "get": {
        "summary": "Return the revalidated Chat session without exposing tokens",
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/tenant": {
      "post": {
        "summary": "Select one active entitled tenant for the current session",
        "requestBody": { "$ref": "#/components/requestBodies/TenantSelection" },
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "403": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/invitations/accept-password": {
      "post": {
        "summary": "Accept a valid invitation for a new or reclaimable local account with a password",
        "requestBody": { "$ref": "#/components/requestBodies/InvitationPasswordAcceptance" },
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "409": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/invitations/bind-existing": {
      "post": {
        "summary": "Bind a valid invitation after normal existing-account authentication",
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSession" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "409": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/invitations/resolve": {
      "get": {
        "summary": "Resolve the server-protected invitation intent without returning the invitation token",
        "responses": {
          "200": { "$ref": "#/components/responses/InvitationSummary" },
          "409": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/api/tenant-chat/auth/google/start": { "$ref": "#/components/pathItems/BrowserMutation" },
    "/api/tenant-chat/auth/google/continue": { "$ref": "#/components/pathItems/BrowserRedirect" },
    "/auth/google/callback": { "$ref": "#/components/pathItems/BrowserRedirect" },
    "/internal/v1/tenant-chat/auth/invitation-intents": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/invitations/resolve": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/invitations/accept-password": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/invitations/bind-existing": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/google/start": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/google/complete": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/session": { "$ref": "#/components/pathItems/PrivateChatRead" },
    "/internal/v1/tenant-chat/auth/tenant": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/refresh": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/auth/logout": { "$ref": "#/components/pathItems/PrivateChatMutation" },
    "/internal/v1/tenant-chat/identity/password": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/invitations/resolve": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/invitations/accept-password": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/invitations/bind-existing": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/google/start": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/google/complete": { "$ref": "#/components/pathItems/PrivateIdentityMutation" },
    "/internal/v1/tenant-chat/identity/entitlements/{userId}": { "$ref": "#/components/pathItems/PrivateIdentityRead" },
    "/internal/v1/tenant-chat/auth/password-reset/request": {
      "post": {
        "summary": "Private Chat API password reset request",
        "security": [{ "chatWebServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetRequest" },
        "responses": {
          "200": { "$ref": "#/components/responses/PasswordResetAccepted" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/auth/password-reset/confirm": {
      "post": {
        "summary": "Private Chat API password reset confirmation",
        "security": [{ "chatWebServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetConfirm" },
        "responses": {
          "200": { "$ref": "#/components/responses/PasswordResetResult" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/auth/password/change": {
      "post": {
        "summary": "Private Chat API password change bound to the active access session",
        "security": [{ "chatWebServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordChange" },
        "responses": {
          "200": { "$ref": "#/components/responses/PasswordChangeResult" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/identity/password-reset/request": {
      "post": {
        "summary": "Private Control Plane password reset request",
        "security": [{ "controlPlaneTenantChatServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetRequest" },
        "responses": {
          "200": { "description": "Data envelope containing the generic accepted result" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/identity/password-reset/confirm": {
      "post": {
        "summary": "Private Control Plane password reset confirmation",
        "security": [{ "controlPlaneTenantChatServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordResetConfirm" },
        "responses": {
          "200": { "description": "Data envelope containing the password reset result" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/identity/password/change": {
      "post": {
        "summary": "Private Control Plane password change for a Chat-authenticated user",
        "security": [{ "controlPlaneTenantChatServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PrivatePasswordChange" },
        "responses": {
          "200": { "description": "Data envelope containing the password change result" },
          "400": { "$ref": "#/components/responses/SafeError" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/auth/password": {
      "post": {
        "summary": "Private Chat API password login",
        "security": [{ "chatWebServiceToken": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/PasswordLogin" },
        "responses": {
          "200": { "$ref": "#/components/responses/InternalIssuedSession" },
          "401": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    },
    "/internal/v1/tenant-chat/identity/entitlements/{userId}/{tenantId}": {
      "get": {
        "summary": "Private Control Plane authoritative entitlement read",
        "security": [{ "controlPlaneTenantChatServiceToken": [] }],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "tenantId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/Entitlement" },
          "403": { "$ref": "#/components/responses/SafeError" },
          "404": { "$ref": "#/components/responses/SafeError" },
          "503": { "$ref": "#/components/responses/SafeError" }
        }
      }
    }
  },
  "components": {
    "pathItems": {
      "BrowserMutation": {
        "post": {
          "summary": "Same-origin CSRF-protected browser auth mutation",
          "responses": {
            "200": { "description": "Safe browser response without access or refresh tokens" },
            "303": { "description": "Allowlisted redirect" },
            "400": { "$ref": "#/components/responses/SafeError" },
            "403": { "$ref": "#/components/responses/SafeError" },
            "503": { "$ref": "#/components/responses/SafeError" }
          }
        }
      },
      "BrowserRedirect": {
        "get": {
          "summary": "Consume protected OAuth state and redirect through an allowlisted location",
          "responses": {
            "303": { "description": "Allowlisted redirect with protected state cleared" }
          }
        }
      },
      "PrivateChatMutation": {
        "post": {
          "summary": "Private Chat API auth mutation",
          "security": [{ "chatWebServiceToken": [] }],
          "responses": {
            "200": { "$ref": "#/components/responses/InternalIssuedSession" },
            "400": { "$ref": "#/components/responses/SafeError" },
            "401": { "$ref": "#/components/responses/SafeError" },
            "403": { "$ref": "#/components/responses/SafeError" },
            "409": { "$ref": "#/components/responses/SafeError" },
            "503": { "$ref": "#/components/responses/SafeError" }
          }
        }
      },
      "PrivateChatRead": {
        "get": {
          "summary": "Private Chat API revalidated session read",
          "security": [{ "chatWebServiceToken": [] }],
          "responses": {
            "200": { "$ref": "#/components/responses/AuthSession" },
            "401": { "$ref": "#/components/responses/SafeError" },
            "403": { "$ref": "#/components/responses/SafeError" },
            "503": { "$ref": "#/components/responses/SafeError" }
          }
        }
      },
      "PrivateIdentityMutation": {
        "post": {
          "summary": "Private Control Plane identity mutation",
          "security": [{ "controlPlaneTenantChatServiceToken": [] }],
          "responses": {
            "200": { "description": "Bounded identity or invitation data envelope" },
            "400": { "$ref": "#/components/responses/SafeError" },
            "401": { "$ref": "#/components/responses/SafeError" },
            "403": { "$ref": "#/components/responses/SafeError" },
            "409": { "$ref": "#/components/responses/SafeError" }
          }
        }
      },
      "PrivateIdentityRead": {
        "get": {
          "summary": "Private Control Plane authoritative entitlement read",
          "security": [{ "controlPlaneTenantChatServiceToken": [] }],
          "responses": {
            "200": { "description": "Authoritative active identity and tenant entitlements" },
            "403": { "$ref": "#/components/responses/SafeError" },
            "404": { "$ref": "#/components/responses/SafeError" }
          }
        }
      }
    },
    "securitySchemes": {
      "chatWebServiceToken": { "type": "apiKey", "in": "header", "name": "X-GateLM-Chat-Web-Service-Token" },
      "controlPlaneTenantChatServiceToken": { "type": "apiKey", "in": "header", "name": "X-GateLM-Tenant-Chat-Service-Token" }
    },
    "schemas": {
      "SafeError": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "maxLength": 64 },
          "message": { "type": "string", "maxLength": 240 },
          "retryAfterSeconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
        },
        "required": ["code", "message"],
        "additionalProperties": false
      },
      "Ok": {
        "type": "object",
        "properties": { "ok": { "type": "boolean", "const": true } },
        "required": ["ok"],
        "additionalProperties": false
      },
      "PasswordLogin": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 254 },
          "password": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "required": ["email", "password"],
        "additionalProperties": false
      },
      "PasswordResetRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 254 }
        },
        "required": ["email"],
        "additionalProperties": false
      },
      "PasswordResetConfirm": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "minLength": 32, "maxLength": 512, "writeOnly": true },
          "newPassword": { "type": "string", "minLength": 15, "maxLength": 256, "writeOnly": true }
        },
        "required": ["token", "newPassword"],
        "additionalProperties": false
      },
      "PasswordChange": {
        "type": "object",
        "properties": {
          "currentPassword": { "type": "string", "minLength": 1, "maxLength": 256, "writeOnly": true },
          "newPassword": { "type": "string", "minLength": 15, "maxLength": 256, "writeOnly": true }
        },
        "required": ["currentPassword", "newPassword"],
        "additionalProperties": false
      },
      "PrivatePasswordChange": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "format": "uuid" },
          "currentPassword": { "type": "string", "minLength": 1, "maxLength": 256, "writeOnly": true },
          "newPassword": { "type": "string", "minLength": 15, "maxLength": 256, "writeOnly": true }
        },
        "required": ["userId", "currentPassword", "newPassword"],
        "additionalProperties": false
      },
      "PasswordResetAccepted": {
        "type": "object",
        "properties": { "accepted": { "type": "boolean", "const": true } },
        "required": ["accepted"],
        "additionalProperties": false
      },
      "PasswordResetResult": {
        "type": "object",
        "properties": { "passwordReset": { "type": "boolean", "const": true } },
        "required": ["passwordReset"],
        "additionalProperties": false
      },
      "PasswordChangeResult": {
        "type": "object",
        "properties": { "passwordChanged": { "type": "boolean", "const": true } },
        "required": ["passwordChanged"],
        "additionalProperties": false
      },
      "TenantSelection": {
        "type": "object",
        "properties": { "tenantId": { "type": "string", "format": "uuid" } },
        "required": ["tenantId"],
        "additionalProperties": false
      },
      "InvitationPasswordAcceptance": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "password": { "type": "string", "minLength": 15, "maxLength": 256 }
        },
        "required": ["name", "password"],
        "additionalProperties": false
      },
      "InvitationSummary": {
        "type": "object",
        "properties": {
          "accountState": {
            "type": "string",
            "enum": ["existing", "new", "reclaimable"],
            "description": "reclaimable is limited to an active local User without a live Employee or Admin affiliation"
          },
          "email": { "type": "string", "format": "email", "maxLength": 254 },
          "employeeName": { "type": ["string", "null"], "maxLength": 120 },
          "expiresAt": { "type": "string", "format": "date-time" },
          "tenantId": { "type": "string", "format": "uuid" },
          "tenantName": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "required": ["accountState", "email", "employeeName", "expiresAt", "tenantId", "tenantName"],
        "additionalProperties": false
      },
      "InternalIssuedSession": {
        "type": "object",
        "description": "Private service-to-service response. Token values are immediately converted to host-only HttpOnly cookies and are never returned by the browser BFF.",
        "properties": {
          "accessToken": { "type": "string", "writeOnly": true, "minLength": 32, "maxLength": 8192 },
          "refreshToken": { "type": "string", "writeOnly": true, "minLength": 32, "maxLength": 512 },
          "accessExpiresAt": { "type": "string", "format": "date-time" },
          "refreshExpiresAt": { "type": "string", "format": "date-time" },
          "session": { "$ref": "../schemas/chat-auth-session.schema.json" }
        },
        "required": ["accessToken", "accessExpiresAt", "refreshExpiresAt", "session"],
        "additionalProperties": false
      },
      "ChatAuthSession": { "$ref": "../schemas/chat-auth-session.schema.json" },
      "ChatEntitlement": { "$ref": "../schemas/chat-entitlement.schema.json" }
    },
    "requestBodies": {
      "PasswordResetRequest": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordResetRequest" } } }
      },
      "PasswordResetConfirm": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordResetConfirm" } } }
      },
      "PasswordChange": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordChange" } } }
      },
      "PrivatePasswordChange": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PrivatePasswordChange" } } }
      },
      "PasswordLogin": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordLogin" } } }
      },
      "TenantSelection": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TenantSelection" } } }
      },
      "InvitationPasswordAcceptance": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InvitationPasswordAcceptance" } } }
      }
    },
    "responses": {
      "PasswordResetAccepted": { "description": "Generic response shared by eligible and ineligible accounts", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordResetAccepted" } } } },
      "PasswordResetResult": { "description": "Password reset completed and all existing sessions revoked", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordResetResult" } } } },
      "PasswordChangeResult": { "description": "Password changed and all existing sessions revoked", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordChangeResult" } } } },
      "Ok": { "description": "Successful operation", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Ok" } } } },
      "AuthSession": { "description": "Token-free public session metadata", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatAuthSession" } } } },
      "InvitationSummary": { "description": "Safe invitation and tenant summary", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InvitationSummary" } } } },
      "Entitlement": { "description": "Authoritative active entitlement", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatEntitlement" } } } },
      "InternalIssuedSession": { "description": "Private issued session material", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InternalIssuedSession" } } } },
      "SafeError": { "description": "Safe bounded error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SafeError" } } } }
    }
  }
}
