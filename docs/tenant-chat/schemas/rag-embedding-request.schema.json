{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/tenant-chat/v1/rag-embedding-request.schema.json",
  "title": "Private RAG embedding request",
  "type": "object",
  "additionalProperties": false,
  "required": ["purpose", "profileVersion", "inputs"],
  "properties": {
    "purpose": {
      "type": "string",
      "enum": ["RAG_INGESTION", "RAG_QUERY"]
    },
    "profileVersion": {
      "type": "integer",
      "const": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 8192,
        "description": "Ephemeral text. Runtime limits use UTF-8 byte/token upper bounds and never log or persist this value in Gateway."
      }
    }
  }
}
