{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/tenant-chat/v1/cost-series.schema.json",
  "title": "Tenant Chat confirmed cost series",
  "type": "object",
  "additionalProperties": false,
  "required": ["surface", "from", "to", "bucket", "generatedAt", "points"],
  "properties": {
    "surface": { "const": "tenant_chat" },
    "from": { "type": "string", "format": "date-time" },
    "to": { "type": "string", "format": "date-time" },
    "bucket": { "type": "string", "enum": ["1s", "7s", "1m", "5m", "1h", "1d"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "points": {
      "type": "array",
      "maxItems": 10080,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["periodStart", "requestCount", "totalTokens", "confirmedCostMicroUsd"],
        "properties": {
          "periodStart": { "type": "string", "format": "date-time" },
          "requestCount": { "type": "integer", "minimum": 0 },
          "totalTokens": { "type": "integer", "minimum": 0 },
          "confirmedCostMicroUsd": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
