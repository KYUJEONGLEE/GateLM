{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/tenant-chat/chat-turn-sse-event.schema.json",
  "title": "Tenant Chat API-facing turn SSE event",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence"],
  "properties": {
    "type": { "enum": ["chat.turn.accepted", "chat.turn.delta", "chat.turn.sources", "chat.turn.citations", "chat.turn.final", "chat.turn.error", "chat.turn.cancelled"] },
    "schemaVersion": { "const": 1 },
    "conversationId": { "$ref": "#/$defs/uuid" },
    "turnId": { "$ref": "#/$defs/uuid" },
    "sequence": { "type": "integer", "minimum": 1 },
    "replayed": { "type": "boolean" },
    "userMessageId": { "$ref": "#/$defs/uuid" },
    "userContent": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "delta": { "type": "string", "minLength": 1, "maxLength": 16384 },
    "messageId": { "$ref": "#/$defs/uuid" },
    "terminalOutcome": { "const": "succeeded" },
    "effectiveModelKey": { "$ref": "#/$defs/modelKey" },
    "quotaState": { "$ref": "#/$defs/policyState" },
    "budgetState": { "$ref": "#/$defs/policyState" },
    "error": { "$ref": "#/$defs/safeError" },
    "citations": {
      "type": "array",
      "maxItems": 12,
      "items": { "$ref": "#/$defs/citation" }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/accepted" },
    { "$ref": "#/$defs/delta" },
    { "$ref": "#/$defs/sources" },
    { "$ref": "#/$defs/citations" },
    { "$ref": "#/$defs/final" },
    { "$ref": "#/$defs/error" },
    { "$ref": "#/$defs/cancelled" }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "modelKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,199}$"
    },
    "base": {
      "type": "object",
      "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence"],
      "properties": {
        "type": { "type": "string" },
        "schemaVersion": { "const": 1 },
        "conversationId": { "$ref": "#/$defs/uuid" },
        "turnId": { "$ref": "#/$defs/uuid" },
        "sequence": { "type": "integer", "minimum": 1 }
      }
    },
    "accepted": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "replayed", "userMessageId", "userContent"],
          "properties": {
            "type": { "const": "chat.turn.accepted" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "const": 1 },
            "replayed": { "type": "boolean" },
            "userMessageId": { "$ref": "#/$defs/uuid" },
            "userContent": {
              "type": "string",
              "minLength": 1,
              "maxLength": 20000,
              "description": "The sanitized content committed as the user message. It is never the original untrusted input."
            }
          }
        }
      ]
    },
    "delta": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "delta"],
          "properties": {
            "type": { "const": "chat.turn.delta" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "delta": { "type": "string", "minLength": 1, "maxLength": 16384 }
          }
        }
      ]
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "documentId", "displayName", "pageStart", "pageEnd", "lineStart", "lineEnd", "ordinal"],
      "properties": {
        "sourceId": { "type": "string", "pattern": "^S[1-9][0-9]{0,2}$" },
        "documentId": { "$ref": "#/$defs/uuid" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 255 },
        "pageStart": { "type": ["integer", "null"], "minimum": 1 },
        "pageEnd": { "type": ["integer", "null"], "minimum": 1 },
        "lineStart": { "type": ["integer", "null"], "minimum": 1 },
        "lineEnd": { "type": ["integer", "null"], "minimum": 1 },
        "ordinal": { "type": "integer", "minimum": 0 },
        "availability": { "enum": ["available", "unavailable"] }
      }
    },
    "sources": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "citations"],
          "properties": {
            "type": { "const": "chat.turn.sources" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "citations": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "#/$defs/citation" } }
          }
        }
      ]
    },
    "citations": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "citations"],
          "properties": {
            "type": { "const": "chat.turn.citations" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "citations": { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/citation" } }
          }
        }
      ]
    },
    "final": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "messageId", "terminalOutcome", "replayed"],
          "properties": {
            "type": { "const": "chat.turn.final" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "messageId": { "$ref": "#/$defs/uuid" },
            "terminalOutcome": { "const": "succeeded" },
            "effectiveModelKey": { "$ref": "#/$defs/modelKey" },
            "cacheOutcome": { "type": "string", "enum": ["off", "hit", "miss"] },
            "quotaState": { "$ref": "#/$defs/policyState" },
            "budgetState": { "$ref": "#/$defs/policyState" },
            "replayed": { "type": "boolean" }
          }
        }
      ]
    },
    "safeError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^CHAT_[A-Z0-9_]{1,59}$" },
        "message": { "type": "string", "minLength": 1, "maxLength": 256 },
        "retryAfterSeconds": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    },
    "policyState": {
      "type": "string",
      "enum": ["normal", "warning", "economy", "blocked"]
    },
    "error": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "error"],
          "properties": {
            "type": { "const": "chat.turn.error" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "error": { "$ref": "#/$defs/safeError" }
          }
        }
      ]
    },
    "cancelled": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "schemaVersion", "conversationId", "turnId", "sequence", "error"],
          "properties": {
            "type": { "const": "chat.turn.cancelled" },
            "schemaVersion": { "const": 1 },
            "conversationId": { "$ref": "#/$defs/uuid" },
            "turnId": { "$ref": "#/$defs/uuid" },
            "sequence": { "type": "integer", "minimum": 2 },
            "error": {
              "allOf": [
                { "$ref": "#/$defs/safeError" },
                { "properties": { "code": { "const": "CHAT_REQUEST_CANCELLED" } } }
              ]
            }
          }
        }
      ]
    }
  }
}
