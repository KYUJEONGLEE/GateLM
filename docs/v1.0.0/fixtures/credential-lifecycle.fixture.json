{
  "fixtureName": "v1-credential-lifecycle",
  "fixtureVersion": "2026-06-27.v1",
  "owner": "control-plane-runtime-policy",
  "producer": "jaehyeok",
  "consumers": [
    "gateway-data-plane-governance",
    "product-experience-demo"
  ],
  "sourceOfTruth": [
    "docs/v1.0.0/contracts.md",
    "docs/v1.0.0/implementation-plan.md",
    "docs/v1.0.0/schemas/credential-lifecycle.schema.json"
  ],
  "notes": [
    "Plaintext values in issue/rotate examples are synthetic and are shown only once.",
    "Admin list/detail responses must not include plaintext or secretHash.",
    "Gateway verification may use secretHash internally but must never log raw credentials.",
    "trim_utf8 means decode plaintext as UTF-8, remove leading and trailing Unicode White_Space characters only, preserve internal whitespace, then hash the UTF-8 bytes of the trimmed result.",
    "secretHash is the logical API/contract field; physical DB columns may be key_hash, token_hash, or secretHash depending on service storage.",
    "Issue requests bind tenant/project/application context from route parameters plus DB lookup, not from untrusted request body context fields."
  ],
  "credentialLifecycle": {
    "schemaVersion": "gatelm.credential-lifecycle.v1",
    "hashing": {
      "algorithm": "sha256",
      "normalization": "trim_utf8_before_hash",
      "trimDefinition": {
        "inputEncoding": "utf8",
        "whitespaceSet": "unicode_white_space",
        "scope": "leading_and_trailing_only",
        "preserveInternalWhitespace": true,
        "hashInput": "utf8_bytes_after_trim"
      },
      "lookup": "prefix_then_hash_compare",
      "rawSecretStorage": false,
      "logicalHashField": "secretHash",
      "storageColumnAliases": ["secretHash", "key_hash", "token_hash"]
    },
    "plaintextDisplayPolicy": {
      "issueResponseContainsPlaintext": true,
      "listResponseContainsPlaintext": false,
      "rotateResponseContainsPlaintext": true,
      "plaintextShownOnce": true
    },
    "forbiddenAdminResponseFields": [
      "secretHash",
      "plaintextAfterFirstResponse",
      "authorizationHeader",
      "rawProviderKey"
    ],
    "gatewayExternalErrorPolicy": {
      "hideInternalCredentialState": true,
      "apiKey": {
        "problemStatuses": ["missing", "malformed", "mismatched", "revoked", "disabled", "expired"],
        "httpStatus": 401,
        "errorCode": "invalid_api_key"
      },
      "appToken": {
        "problemStatuses": ["missing", "malformed", "mismatched", "revoked", "disabled", "expired"],
        "httpStatus": 403,
        "errorCode": "invalid_app_token"
      },
      "forbiddenExternalFields": [
        "rawCredential",
        "authorizationHeader",
        "appTokenHeader",
        "secretHash",
        "internalCredentialStatus"
      ]
    },
    "apiKey": {
      "credentialType": "api_key",
      "rawTokenPrefix": "gsk_live_",
      "transport": {
        "headerName": "Authorization",
        "valueFormat": "Bearer <plaintext>"
      },
      "binding": ["tenantId", "projectId"],
      "issueBinding": {
        "source": "route_param_db_lookup",
        "pathParam": "projectId",
        "dbLookupResolves": ["tenantId", "projectId"]
      },
      "defaultScopes": ["chat:completions", "models:read"],
      "lifecycle": {
        "allowedStatuses": ["active", "revoked", "expired", "disabled"],
        "rotatePreviousStatus": "revoked",
        "revokeTargetStatus": "revoked",
        "rotatePolicy": {
          "allowedStatus": "active",
          "unexpiredRequired": true,
          "expiredWhen": "expiresAt != null && expiresAt <= now",
          "failureHttpStatus": 409,
          "failureErrorCode": "conflict"
        },
        "revokePolicy": {
          "targetStatus": "revoked",
          "allowedSourceStatuses": ["active", "revoked", "expired", "disabled"],
          "idempotentWhenStatus": "revoked",
          "preserveExistingRevokedAt": true
        }
      },
      "issueExample": {
        "request": {
          "tenantId": "tenant_demo_acme",
          "projectId": "project_customer_support",
          "applicationId": null,
          "displayName": "Primary Gateway API Key",
          "scopes": ["chat:completions", "models:read"],
          "expiresAt": null
        },
        "response": {
          "credentialId": "api_key_demo_primary",
          "credentialType": "api_key",
          "plaintext": "gsk_live_demo_only_9xA1",
          "plaintextShownOnce": true,
          "prefix": "gsk_live_",
          "last4": "9xA1",
          "status": "active",
          "scopes": ["chat:completions", "models:read"],
          "createdAt": "2026-06-27T02:00:00.000Z",
          "expiresAt": null,
          "warning": "Store this value now. GateLM will not show it again."
        }
      },
      "listItemExample": {
        "credentialId": "api_key_demo_primary",
        "credentialType": "api_key",
        "displayName": "Primary Gateway API Key",
        "prefix": "gsk_live_",
        "last4": "9xA1",
        "status": "active",
        "scopes": ["chat:completions", "models:read"],
        "createdAt": "2026-06-27T02:00:00.000Z",
        "expiresAt": null,
        "lastUsedAt": null
      },
      "gatewayVerificationRecord": {
        "credentialId": "api_key_demo_primary",
        "credentialType": "api_key",
        "tenantId": "tenant_demo_acme",
        "projectId": "project_customer_support",
        "applicationId": null,
        "prefix": "gsk_live_",
        "secretHash": "sha256_demo_api_key_hash_9xA1",
        "hashAlgorithm": "sha256",
        "status": "active",
        "scopes": ["chat:completions", "models:read"],
        "expiresAt": null
      },
      "rotateExample": {
        "request": {
          "credentialId": "api_key_demo_primary"
        },
        "response": {
          "credentialId": "api_key_demo_rotated",
          "credentialType": "api_key",
          "plaintext": "gsk_live_demo_rotated_7mQ3",
          "plaintextShownOnce": true,
          "prefix": "gsk_live_",
          "last4": "7mQ3",
          "status": "active",
          "scopes": ["chat:completions", "models:read"],
          "createdAt": "2026-06-27T02:10:00.000Z",
          "expiresAt": null,
          "warning": "Store this value now. GateLM will not show it again."
        },
        "previousCredentialStatusAfterRotate": "revoked"
      },
      "rotateRejectedExamples": [
        {
          "credentialId": "api_key_demo_revoked",
          "status": "revoked",
          "expiresAt": null,
          "httpStatus": 409,
          "errorCode": "conflict"
        },
        {
          "credentialId": "api_key_demo_expired",
          "status": "active",
          "expiresAt": "2026-06-27T01:00:00.000Z",
          "httpStatus": 409,
          "errorCode": "conflict"
        }
      ],
      "revokeExample": {
        "request": {
          "credentialId": "api_key_demo_primary"
        },
        "response": {
          "credentialId": "api_key_demo_primary",
          "status": "revoked",
          "revokedAt": "2026-06-27T02:15:00.000Z"
        }
      },
      "revokeIdempotentExample": {
        "request": {
          "credentialId": "api_key_demo_primary"
        },
        "existingCredentialStatus": "revoked",
        "existingRevokedAt": "2026-06-27T02:15:00.000Z",
        "response": {
          "credentialId": "api_key_demo_primary",
          "status": "revoked",
          "revokedAt": "2026-06-27T02:15:00.000Z"
        }
      }
    },
    "appToken": {
      "credentialType": "app_token",
      "rawTokenPrefix": "gat_app_",
      "transport": {
        "headerName": "X-GateLM-App-Token",
        "valueFormat": "<plaintext>"
      },
      "binding": ["tenantId", "projectId", "applicationId"],
      "issueBinding": {
        "source": "route_param_db_lookup",
        "pathParam": "applicationId",
        "dbLookupResolves": ["tenantId", "projectId", "applicationId"]
      },
      "defaultScopes": ["gateway:invoke"],
      "lifecycle": {
        "allowedStatuses": ["active", "revoked", "expired", "disabled"],
        "rotatePreviousStatus": "revoked",
        "revokeTargetStatus": "revoked",
        "rotatePolicy": {
          "allowedStatus": "active",
          "unexpiredRequired": true,
          "expiredWhen": "expiresAt != null && expiresAt <= now",
          "failureHttpStatus": 409,
          "failureErrorCode": "conflict"
        },
        "revokePolicy": {
          "targetStatus": "revoked",
          "allowedSourceStatuses": ["active", "revoked", "expired", "disabled"],
          "idempotentWhenStatus": "revoked",
          "preserveExistingRevokedAt": true
        }
      },
      "issueExample": {
        "request": {
          "tenantId": "tenant_demo_acme",
          "projectId": "project_customer_support",
          "applicationId": "app_customer_demo",
          "displayName": "Customer Demo App Token",
          "scopes": ["gateway:invoke"],
          "expiresAt": null
        },
        "response": {
