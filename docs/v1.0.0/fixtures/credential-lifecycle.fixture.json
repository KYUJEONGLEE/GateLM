      },
      "gatewayVerificationRecord": {
        "credentialId": "app_token_demo_customer_app",
        "credentialType": "app_token",
        "tenantId": "tenant_demo_acme",
        "projectId": "project_customer_support",
        "applicationId": "app_customer_demo",
        "prefix": "gat_app_",
        "secretHash": "sha256_demo_app_token_hash_4tK2",
        "hashAlgorithm": "sha256",
        "status": "active",
        "scopes": ["gateway:invoke"],
        "expiresAt": null
      },
      "rotateExample": {
        "request": {
