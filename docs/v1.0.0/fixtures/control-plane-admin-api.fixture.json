        "operationId": "listAppTokens",
        "method": "GET",
        "path": "/admin/v1/applications/{applicationId}/app-tokens",
        "owner": "control-plane-runtime-policy",
        "consumer": "product-experience-demo",
        "requestContract": "ListAppTokensQuery",
        "responseContract": "AppTokenListResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": true,
        "notes": ["List response must not include plaintext or secretHash."]
      },
      {
        "operationId": "rotateAppToken",
        "method": "POST",
        "path": "/admin/v1/app-tokens/{appTokenId}/rotate",
        "owner": "control-plane-runtime-policy",
        "consumer": "product-experience-demo",
        "requestContract": "RotateAppTokenRequest",
        "responseContract": "OneTimeAppTokenResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": false,
        "notes": [
          "Previous App Token status becomes revoked.",
          "Only active and unexpired App Tokens may be rotated.",
          "Revoked, disabled, expired, or already-expired App Tokens fail with 409 conflict."
        ]
      },
      {
        "operationId": "revokeAppToken",
        "method": "POST",
        "path": "/admin/v1/app-tokens/{appTokenId}/revoke",
        "owner": "control-plane-runtime-policy",
        "consumer": "product-experience-demo",
        "requestContract": "RevokeAppTokenRequest",
        "responseContract": "CredentialRevokedResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": true,
        "notes": [
          "Gateway must reject revoked App Tokens as invalid_app_token.",
          "Revoke is a final disposal command and may target active, disabled, expired, or revoked App Tokens.",
          "If the App Token is already revoked, Control Plane must not update DB state and must return the existing revokedAt."
        ]
      },
      {
        "operationId": "getActiveRuntimeConfig",
        "method": "GET",
        "path": "/admin/v1/applications/{applicationId}/runtime-config/active",
        "owner": "control-plane-runtime-policy",
        "consumer": "gateway-data-plane-governance",
        "requestContract": "GetActiveRuntimeConfigQuery",
        "responseContract": "ActiveRuntimeConfigResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": true,
        "notes": ["Response body must conform to runtime-config.schema.json runtimeConfig."]
      },
      {
        "operationId": "upsertRuntimeConfigDraft",
        "method": "POST",
        "path": "/admin/v1/applications/{applicationId}/runtime-config/draft",
        "owner": "control-plane-runtime-policy",
        "consumer": "product-experience-demo",
        "requestContract": "UpsertRuntimeConfigDraftRequest",
        "responseContract": "RuntimeConfigDraftResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": false,
        "notes": ["Creates or updates a draft without changing the active config."]
      },
      {
        "operationId": "publishRuntimeConfig",
        "method": "POST",
        "path": "/admin/v1/applications/{applicationId}/runtime-config/publish",
        "owner": "control-plane-runtime-policy",
        "consumer": "product-experience-demo",
        "requestContract": "PublishRuntimeConfigRequest",
        "responseContract": "ActiveRuntimeConfigResponse",
        "successStatus": 200,
        "authRequired": true,
        "idempotency": false,
        "notes": ["Publishes a new active configVersion and configHash."]
      }
