{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/docs/v1.0.0/schemas/credential-lifecycle.schema.json",
  "title": "GateLM v1 Credential Lifecycle Fixture",
  "description": "API Key and App Token issue/list/rotate/revoke contract for Control Plane, Web, and Gateway verification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureName",
    "fixtureVersion",
    "owner",
    "producer",
    "consumers",
    "sourceOfTruth",
    "notes",
    "credentialLifecycle"
  ],
  "properties": {
    "fixtureName": { "$ref": "#/$defs/nonEmptyString" },
    "fixtureVersion": { "$ref": "#/$defs/nonEmptyString" },
    "owner": { "$ref": "#/$defs/nonEmptyString" },
    "producer": { "$ref": "#/$defs/nonEmptyString" },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "sourceOfTruth": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "credentialLifecycle": { "$ref": "#/$defs/credentialLifecycle" }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableDateTime": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "credentialStatus": {
      "enum": ["active", "revoked", "expired", "disabled"]
    },
    "credentialLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "hashing",
        "plaintextDisplayPolicy",
        "forbiddenAdminResponseFields",
        "apiKey",
        "appToken"
      ],
      "properties": {
        "schemaVersion": { "const": "gatelm.credential-lifecycle.v1" },
        "hashing": { "$ref": "#/$defs/hashing" },
        "plaintextDisplayPolicy": { "$ref": "#/$defs/plaintextDisplayPolicy" },
        "forbiddenAdminResponseFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "apiKey": { "$ref": "#/$defs/credentialContract" },
        "appToken": { "$ref": "#/$defs/credentialContract" }
      }
    },
    "hashing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "normalization",
        "lookup",
        "rawSecretStorage",
        "logicalHashField",
        "storageColumnAliases"
      ],
      "properties": {
        "algorithm": { "const": "sha256" },
        "normalization": { "const": "trim_utf8_before_hash" },
        "lookup": { "const": "prefix_then_hash_compare" },
        "rawSecretStorage": { "const": false },
        "logicalHashField": { "const": "secretHash" },
        "storageColumnAliases": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        }
      }
    },
    "plaintextDisplayPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issueResponseContainsPlaintext",
        "listResponseContainsPlaintext",
        "rotateResponseContainsPlaintext",
        "plaintextShownOnce"
      ],
      "properties": {
        "issueResponseContainsPlaintext": { "const": true },
        "listResponseContainsPlaintext": { "const": false },
        "rotateResponseContainsPlaintext": { "const": true },
        "plaintextShownOnce": { "const": true }
      }
    },
    "credentialContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialType",
        "rawTokenPrefix",
        "transport",
        "binding",
        "issueBinding",
        "defaultScopes",
        "lifecycle",
        "issueExample",
        "listItemExample",
        "gatewayVerificationRecord",
        "rotateExample",
        "rotateRejectedExamples",
        "revokeExample",
        "revokeIdempotentExample"
      ],
      "properties": {
        "credentialType": { "enum": ["api_key", "app_token"] },
        "rawTokenPrefix": { "$ref": "#/$defs/nonEmptyString" },
        "transport": { "$ref": "#/$defs/transport" },
        "binding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["tenantId", "projectId", "applicationId"]
          },
          "uniqueItems": true
        },
        "issueBinding": { "$ref": "#/$defs/issueBinding" },
        "defaultScopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "lifecycle": { "$ref": "#/$defs/lifecycle" },
        "issueExample": { "$ref": "#/$defs/issueExample" },
        "listItemExample": { "$ref": "#/$defs/listItem" },
        "gatewayVerificationRecord": { "$ref": "#/$defs/gatewayVerificationRecord" },
        "rotateExample": { "$ref": "#/$defs/rotateExample" },
        "rotateRejectedExamples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rotateRejectedExample" }
        },
        "revokeExample": { "$ref": "#/$defs/revokeExample" },
        "revokeIdempotentExample": { "$ref": "#/$defs/revokeIdempotentExample" }
      }
    },
    "issueBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "pathParam", "dbLookupResolves"],
      "properties": {
        "source": { "const": "route_param_db_lookup" },
        "pathParam": { "enum": ["projectId", "applicationId"] },
        "dbLookupResolves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["tenantId", "projectId", "applicationId"]
          },
          "uniqueItems": true
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headerName", "valueFormat"],
      "properties": {
        "headerName": { "$ref": "#/$defs/nonEmptyString" },
        "valueFormat": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedStatuses",
        "rotatePreviousStatus",
        "revokeTargetStatus",
        "rotatePolicy",
        "revokePolicy"
      ],
      "properties": {
        "allowedStatuses": {
          "type": "array",
          "items": { "$ref": "#/$defs/credentialStatus" },
          "uniqueItems": true
        },
        "rotatePreviousStatus": { "const": "revoked" },
        "revokeTargetStatus": { "const": "revoked" },
        "rotatePolicy": { "$ref": "#/$defs/rotatePolicy" },
        "revokePolicy": { "$ref": "#/$defs/revokePolicy" }
      }
    },
    "rotatePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedStatus",
        "unexpiredRequired",
        "expiredWhen",
        "failureHttpStatus",
        "failureErrorCode"
      ],
      "properties": {
        "allowedStatus": { "const": "active" },
        "unexpiredRequired": { "const": true },
        "expiredWhen": { "const": "expiresAt != null && expiresAt <= now" },
        "failureHttpStatus": { "const": 409 },
        "failureErrorCode": { "const": "conflict" }
      }
    },
    "revokePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetStatus",
        "allowedSourceStatuses",
        "idempotentWhenStatus",
        "preserveExistingRevokedAt"
      ],
      "properties": {
        "targetStatus": { "const": "revoked" },
        "allowedSourceStatuses": {
          "type": "array",
          "items": { "$ref": "#/$defs/credentialStatus" },
          "uniqueItems": true
        },
        "idempotentWhenStatus": { "const": "revoked" },
        "preserveExistingRevokedAt": { "const": true }
      }
    },
    "issueExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "response"],
      "properties": {
        "request": { "$ref": "#/$defs/issueRequest" },
        "response": { "$ref": "#/$defs/issueResponse" }
      }
    },
    "issueRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenantId", "projectId", "applicationId", "displayName", "scopes", "expiresAt"],
      "properties": {
        "tenantId": { "$ref": "#/$defs/nonEmptyString" },
        "projectId": { "$ref": "#/$defs/nonEmptyString" },
        "applicationId": { "$ref": "#/$defs/nullableString" },
        "displayName": { "$ref": "#/$defs/nonEmptyString" },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "expiresAt": { "$ref": "#/$defs/nullableDateTime" }
      }
    },
    "issueResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialId",
        "credentialType",
        "plaintext",
        "plaintextShownOnce",
        "prefix",
        "last4",
        "status",
        "scopes",
        "createdAt",
        "expiresAt",
        "warning"
      ],
      "properties": {
        "credentialId": { "$ref": "#/$defs/nonEmptyString" },
        "credentialType": { "enum": ["api_key", "app_token"] },
        "plaintext": { "$ref": "#/$defs/nonEmptyString" },
        "plaintextShownOnce": { "const": true },
        "prefix": { "$ref": "#/$defs/nonEmptyString" },
        "last4": {
          "type": "string",
          "minLength": 4,
          "maxLength": 4
        },
        "status": { "$ref": "#/$defs/credentialStatus" },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "createdAt": { "$ref": "#/$defs/dateTime" },
        "expiresAt": { "$ref": "#/$defs/nullableDateTime" },
        "warning": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "listItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialId",
        "credentialType",
        "displayName",
        "prefix",
        "last4",
        "status",
        "scopes",
        "createdAt",
        "expiresAt",
        "lastUsedAt"
      ],
      "properties": {
        "credentialId": { "$ref": "#/$defs/nonEmptyString" },
        "credentialType": { "enum": ["api_key", "app_token"] },
        "displayName": { "$ref": "#/$defs/nonEmptyString" },
        "prefix": { "$ref": "#/$defs/nonEmptyString" },
        "last4": {
          "type": "string",
          "minLength": 4,
          "maxLength": 4
        },
        "status": { "$ref": "#/$defs/credentialStatus" },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "createdAt": { "$ref": "#/$defs/dateTime" },
        "expiresAt": { "$ref": "#/$defs/nullableDateTime" },
        "lastUsedAt": { "$ref": "#/$defs/nullableDateTime" }
      }
    },
    "gatewayVerificationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentialId",
        "credentialType",
        "tenantId",
        "projectId",
        "applicationId",
        "prefix",
        "secretHash",
        "hashAlgorithm",
        "status",
        "scopes",
        "expiresAt"
      ],
      "properties": {
        "credentialId": { "$ref": "#/$defs/nonEmptyString" },
        "credentialType": { "enum": ["api_key", "app_token"] },
        "tenantId": { "$ref": "#/$defs/nonEmptyString" },
        "projectId": { "$ref": "#/$defs/nonEmptyString" },
        "applicationId": { "$ref": "#/$defs/nullableString" },
        "prefix": { "$ref": "#/$defs/nonEmptyString" },
        "secretHash": { "$ref": "#/$defs/nonEmptyString" },
        "hashAlgorithm": { "const": "sha256" },
        "status": { "$ref": "#/$defs/credentialStatus" },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "expiresAt": { "$ref": "#/$defs/nullableDateTime" }
      }
    },
    "rotateExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "response", "previousCredentialStatusAfterRotate"],
      "properties": {
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["credentialId"],
          "properties": {
            "credentialId": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "response": { "$ref": "#/$defs/issueResponse" },
        "previousCredentialStatusAfterRotate": { "const": "revoked" }
      }
    },
    "rotateRejectedExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credentialId", "status", "expiresAt", "httpStatus", "errorCode"],
      "properties": {
        "credentialId": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "$ref": "#/$defs/credentialStatus" },
        "expiresAt": { "$ref": "#/$defs/nullableDateTime" },
        "httpStatus": { "const": 409 },
        "errorCode": { "const": "conflict" }
      }
    },
    "revokeExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "response"],
      "properties": {
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["credentialId"],
          "properties": {
            "credentialId": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "response": { "$ref": "#/$defs/revokeResponse" }
      }
    },
    "revokeIdempotentExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "existingCredentialStatus", "existingRevokedAt", "response"],
      "properties": {
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["credentialId"],
          "properties": {
            "credentialId": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "existingCredentialStatus": { "const": "revoked" },
        "existingRevokedAt": { "$ref": "#/$defs/dateTime" },
        "response": { "$ref": "#/$defs/revokeResponse" }
      }
    },
    "revokeResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credentialId", "status", "revokedAt"],
      "properties": {
        "credentialId": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "const": "revoked" },
        "revokedAt": { "$ref": "#/$defs/dateTime" }
      }
    }
  }
}
