{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/ai-safety-lab/detector-sidecar-batch-request.schema.json",
  "title": "GateLM AI Safety Detector Batch Request",
  "description": "Internal transient request contract. promptText values must never be logged or stored.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "mode",
    "model",
    "inputs",
    "detectorConfig"
  ],
  "properties": {
    "contractVersion": {
      "const": "ai-safety-detector-batch.v1"
    },
    "mode": {
      "enum": [
        "enforce",
        "shadow"
      ]
    },
    "model": {
      "$ref": "detector-sidecar-response.schema.json#/$defs/model"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "itemIndex",
          "promptText"
        ],
        "properties": {
          "itemIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 63
          },
          "promptText": {
            "type": "string",
            "minLength": 1,
            "description": "Transient locally-redacted Provider-bound text. Forbidden in logs, errors, fixtures, and storage."
          },
          "locale": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      }
    },
    "detectorConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detectorSet",
        "returnConfidence"
      ],
      "properties": {
        "detectorSet": {
          "type": "string",
          "minLength": 1
        },
        "returnConfidence": {
          "type": "boolean"
        },
        "detectorPolicies": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "detectorType",
              "action"
            ],
            "properties": {
              "detectorType": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "action": {
                "enum": [
                  "allow",
                  "redact",
                  "block"
                ]
              }
            }
          }
        }
      }
    }
  }
}
