{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/ai-safety-lab/master-eval-case.schema.json",
  "title": "GateLM AI Safety Lab Master Eval Case",
  "description": "Single synthetic placeholder-based eval case with target-specific expectations for Gateway and detector evaluation. Fixtures must not contain real customer text, real email, real phone number, real token, real credential, raw detected value, raw offset, or raw span.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "locale",
    "inputTemplate",
    "placeholderBindings",
    "expectations",
    "tags"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "locale": {
      "type": "string",
      "minLength": 1
    },
    "inputTemplate": {
      "description": "Synthetic template only. Use placeholder tokens such as SYNTHETIC_* instead of real sensitive values.",
      "type": "string",
      "minLength": 1
    },
    "placeholderBindings": {
      "type": "object",
      "additionalProperties": {
        "description": "GateLM-normalized detector type label.",
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "propertyNames": {
        "pattern": "^SYNTHETIC_[A-Z0-9_]+$"
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gateway",
        "detector"
      ],
      "properties": {
        "gateway": {
          "$ref": "#/$defs/gatewayExpectation"
        },
        "detector": {
          "$ref": "#/$defs/detectorExpectation"
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    }
  },
  "$defs": {
    "gatewayExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safetyOutcome",
        "providerCalled",
        "cacheLookup",
        "streamingStarted",
        "terminalStatus",
        "httpStatus",
        "errorCode"
      ],
      "properties": {
        "safetyOutcome": {
          "enum": [
            "passed",
            "redacted",
            "blocked"
          ]
        },
        "providerCalled": {
          "type": "boolean"
        },
        "cacheLookup": {
          "type": "boolean"
        },
        "streamingStarted": {
          "type": "boolean"
        },
        "terminalStatus": {
          "enum": [
            "success",
            "blocked",
            "rate_limited",
            "failed",
            "cancelled"
          ]
        },
        "httpStatus": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "errorCode": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "detectorExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "mode",
        "detectedTypes",
        "detectedCount",
        "blockReason"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "passed",
            "redacted",
            "blocked"
          ]
        },
        "mode": {
          "enum": [
            "shadow",
            "enforce"
          ]
        },
        "detectedTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "detectedCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockReason": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    }
  }
}
