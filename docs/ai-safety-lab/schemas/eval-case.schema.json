{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/ai-safety-lab/eval-case.schema.json",
  "title": "GateLM AI Safety Lab Eval Case",
  "description": "Synthetic placeholder-based eval case. Fixtures must not contain real customer text, real email, real phone number, real token, real credential, raw detected value, raw offset, or raw span.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "inputTemplate",
    "placeholderBindings",
    "expectedSafetyDecision",
    "expectedGatewayEffects",
    "tags"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "inputTemplate": {
      "description": "Synthetic template only. Use placeholder tokens such as SYNTHETIC_* instead of real sensitive values.",
      "type": "string",
      "minLength": 1
    },
    "placeholderBindings": {
      "type": "object",
      "additionalProperties": {
        "description": "GateLM-normalized detector type label such as email, person_name, or organization_name.",
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "propertyNames": {
        "pattern": "^SYNTHETIC_[A-Z0-9_]+$"
      }
    },
    "expectedSafetyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "mode",
        "detectedTypes",
        "detectedCount",
        "redactedPromptPreview",
        "blockReason",
        "policyVersion"
      ],
      "properties": {
        "action": {
          "enum": [
            "none",
            "redacted",
            "blocked"
          ]
        },
        "mode": {
          "enum": [
            "enforce",
            "shadow"
          ]
        },
        "detectedTypes": {
          "description": "GateLM-normalized detector type labels such as email, person_name, or organization_name.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "detectedCount": {
          "type": "integer",
          "minimum": 0
        },
        "redactedPromptPreview": {
          "type": [
            "string",
            "null"
          ]
        },
        "blockReason": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "policyVersion": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:-]*$"
        }
      }
    },
    "expectedGatewayEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerCalled",
        "cacheLookup",
        "streamingStarted",
        "terminalStatus",
        "httpStatus",
        "errorCode"
      ],
      "properties": {
        "providerCalled": {
          "type": "boolean"
        },
        "cacheLookup": {
          "type": "boolean"
        },
        "streamingStarted": {
          "type": "boolean"
        },
        "terminalStatus": {
          "enum": [
            "success",
            "blocked",
            "rate_limited",
            "failed",
            "cancelled"
          ]
        },
        "httpStatus": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "errorCode": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    }
  }
}
