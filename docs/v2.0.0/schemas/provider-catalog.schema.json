{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/v2.0.0/provider-catalog.schema.json",
  "title": "GateLM v2.0.0 Provider Catalog",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "catalogId": {
      "type": "string",
      "minLength": 1,
      "description": "Provider/Model catalog identifier produced by Control Plane."
    },
    "catalogVersion": {
      "type": "integer",
      "minimum": 1
    },
    "contentHash": {
      "type": "string",
      "minLength": 1,
      "description": "Sanitized catalog fingerprint. It must not reveal credential material."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/provider"
      }
    }
  },
  "required": [
    "catalogId",
    "catalogVersion",
    "contentHash",
    "providers"
  ],
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "providerName": {
          "type": "string",
          "minLength": 1,
          "description": "Admin/catalog-facing provider name. It is data and must not be represented as a DB/code enum. Gateway adapter dispatch must not use this field."
        },
        "adapterType": {
          "type": "string",
          "minLength": 1,
          "description": "Gateway adapter kind such as openai_compatible or mock. This is catalog/config data, not a DB/code enum."
        },
        "enabled": {
          "type": "boolean"
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1,
          "format": "uri",
          "description": "Provider API base URL used by the Gateway adapter. It must not contain credentials or Authorization material."
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 300000,
          "description": "Provider call timeout in milliseconds."
        },
        "credentialRequired": {
          "type": "boolean",
          "description": "Whether this provider requires a credentialRef before Gateway may call it. false is reserved for Mock, local, or explicitly no-auth providers."
        },
        "credentialRef": {
          "anyOf": [
            {
              "$ref": "#/$defs/credentialRef"
            },
            {
              "type": "null"
            }
          ],
          "description": "Reference or metadata only when credentials are required. Null is allowed only for explicit no-credential provider paths."
        },
        "adapterConfig": {
          "$ref": "#/$defs/adapterConfig"
        },
        "fallbackEligible": {
          "type": "boolean"
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/model"
          }
        }
      },
      "required": [
        "providerId",
        "providerName",
        "adapterType",
        "enabled",
        "baseUrl",
        "timeoutMs",
        "credentialRequired",
        "credentialRef",
        "adapterConfig",
        "models"
      ]
    },
    "adapterConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "Allowlisted adapter execution config. It must not contain provider keys, Authorization headers, secret plaintext, or raw provider error bodies.",
      "properties": {
        "requestFormat": {
          "type": "string",
          "enum": [
            "openai_chat_completions",
            "mock_chat_completions"
          ],
          "description": "Wire request format used by the Provider Adapter."
        },
        "apiVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z0-9._-]+$",
          "description": "Optional allowlisted provider API version, for example Azure-style OpenAI-compatible endpoints. It must not contain credentials, headers, or free-form query material."
        }
      },
      "required": [
        "requestFormat"
      ]
    },
    "credentialRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reference or metadata only. API Key, App Token, Provider Key, Authorization header, and secret plaintext are forbidden.",
      "properties": {
        "credentialRefId": {
          "type": "string",
          "minLength": 1
        },
        "credentialVersion": {
          "type": "integer",
          "minimum": 1
        },
        "credentialState": {
          "type": "string",
          "enum": [
            "active",
            "rotating",
            "disabled"
          ]
        },
        "credentialHash": {
          "type": "string",
          "minLength": 1,
          "description": "Optional credential reference fingerprint. It must not be derived into or expose the raw provider key."
        }
      },
      "required": [
        "credentialRefId",
        "credentialVersion",
        "credentialState"
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modelId": {
          "type": "string",
          "minLength": 1,
          "description": "GateLM internal model identifier. This value is not necessarily sent to the upstream provider."
        },
        "modelName": {
          "type": "string",
          "minLength": 1,
          "description": "Provider API model name. This value is data and must not be represented as a DB/code enum."
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "capabilities": {
          "$ref": "#/$defs/modelCapabilities"
        },
        "routing": {
          "$ref": "#/$defs/modelRouting"
        }
      },
      "required": [
        "modelId",
        "modelName",
        "enabled",
        "capabilities"
      ]
    },
    "modelCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "streamingSupported": {
          "type": "boolean"
        },
        "supportsJsonMode": {
          "type": "boolean"
        },
        "maxInputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "streamingSupported",
        "supportsJsonMode",
        "maxInputTokens",
        "maxOutputTokens"
      ]
    },
    "modelRouting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoRoutingEligible": {
          "type": "boolean"
        },
        "costTier": {
          "type": "string",
          "enum": [
            "low",
            "balanced",
            "premium"
          ],
          "description": "routing hint. This is not a provider/model enum."
        },
        "fallbackPriority": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "autoRoutingEligible"
      ]
    }
  }
}
