{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/v2.0.0/draft/provider-catalog.schema.json",
  "title": "GateLM v2.0.0 Provider Catalog Draft",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "catalogId": {
      "type": "string",
      "minLength": 1,
      "description": "Provider/Model catalog identifier produced by Control Plane."
    },
    "catalogVersion": {
      "type": "integer",
      "minimum": 1
    },
    "contentHash": {
      "type": "string",
      "minLength": 1,
      "description": "Sanitized catalog fingerprint. It must not reveal credential material."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/provider"
      }
    }
  },
  "required": [
    "catalogId",
    "catalogVersion",
    "contentHash",
    "providers"
  ],
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "providerName": {
          "type": "string",
          "minLength": 1,
          "description": "Provider name is data and must not be represented as a DB/code enum."
        },
        "adapterType": {
          "type": "string",
          "minLength": 1,
          "description": "Adapter type is a catalog value. Gateway dispatch should go through Provider Adapter boundaries."
        },
        "enabled": {
          "type": "boolean"
        },
        "credentialRef": {
          "$ref": "#/$defs/credentialRef"
        },
        "fallbackEligible": {
          "type": "boolean"
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/model"
          }
        }
      },
      "required": [
        "providerId",
        "providerName",
        "adapterType",
        "enabled",
        "credentialRef",
        "models"
      ]
    },
    "credentialRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reference or metadata only. API Key, App Token, Provider Key, Authorization header, and secret plaintext are forbidden.",
      "properties": {
        "credentialRefId": {
          "type": "string",
          "minLength": 1
        },
        "credentialVersion": {
          "type": "integer",
          "minimum": 1
        },
        "credentialState": {
          "type": "string",
          "enum": [
            "active",
            "rotating",
            "disabled"
          ]
        },
        "credentialHash": {
          "type": "string",
          "minLength": 1,
          "description": "Optional credential reference fingerprint. It must not be derived into or expose the raw provider key."
        }
      },
      "required": [
        "credentialRefId",
        "credentialVersion",
        "credentialState"
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modelId": {
          "type": "string",
          "minLength": 1
        },
        "modelName": {
          "type": "string",
          "minLength": 1,
          "description": "Model name is data and must not be represented as a DB/code enum."
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "capabilities": {
          "$ref": "#/$defs/modelCapabilities"
        },
        "routing": {
          "$ref": "#/$defs/modelRouting"
        }
      },
      "required": [
        "modelId",
        "modelName",
        "enabled",
        "capabilities"
      ]
    },
    "modelCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "streamingSupported": {
          "type": "boolean"
        },
        "maxInputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "streamingSupported"
      ]
    },
    "modelRouting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoRoutingEligible": {
          "type": "boolean"
        },
        "costTier": {
          "type": "string",
          "enum": [
            "low",
            "balanced",
            "premium"
          ],
          "description": "Draft routing hint. This is not a provider/model enum."
        },
        "fallbackPriority": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "autoRoutingEligible"
      ]
    }
  }
}
