{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/schemas/v2.0.0/kyumin-frontend-read-model.schema.json",
  "title": "GateLM v2 Kyumin Frontend Read Model",
  "description": "Schema for Product Experience and Demo frontend read models. This file is owned by Kyumin and defines the frontend-specific read model surface for v2.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "owner",
    "sourceContract",
    "readModels"
  ],
  "properties": {
    "schemaVersion": {
      "const": "gatelm.kyumin.frontend-read-model.v2.0.0"
    },
    "owner": {
      "const": "kyumin"
    },
    "sourceContract": {
      "const": "docs/v2.0.0/contracts.md"
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "readModels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "employeeChat",
        "requestLogList",
        "requestDetail",
        "dashboardOverview",
        "demoScenarioRunner"
      ],
      "properties": {
        "employeeChat": {
          "$ref": "#/$defs/employeeChatReadModel"
        },
        "requestLogList": {
          "$ref": "#/$defs/requestLogListReadModel"
        },
        "requestDetail": {
          "$ref": "#/$defs/requestDetailReadModel"
        },
        "dashboardOverview": {
          "$ref": "#/$defs/dashboardOverviewReadModel"
        },
        "demoScenarioRunner": {
          "$ref": "#/$defs/demoScenarioRunnerReadModel"
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableDateTime": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "terminalStatus": {
      "enum": [
        "success",
        "blocked",
        "rate_limited",
        "failed",
        "cancelled"
      ]
    },
    "httpStatus": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "budgetScopeType": {
      "enum": [
        "application",
        "project",
        "team"
      ]
    },
    "queryBudgetState": {
      "enum": [
        "ok",
        "too_broad",
        "partial",
        "stale",
        "unavailable"
      ]
    },
    "runtimeState": {
      "description": "Runtime domain outcome/read-model state. no_snapshot/not_checked are not allowed inside RuntimeSnapshot provenance.",
      "enum": [
        "snapshot_active",
        "last_known_safe_used",
        "stale_snapshot_used",
        "no_snapshot",
        "not_checked"
      ]
    },
    "runtimeProvenanceState": {
      "enum": [
        "snapshot_active",
        "last_known_safe_used",
        "stale_snapshot_used"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenantId",
        "projectId",
        "applicationId"
      ],
      "properties": {
        "tenantId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "projectId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "applicationId": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "budgetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budgetScopeType",
        "budgetScopeId",
        "resolvedBy"
      ],
      "properties": {
        "budgetScopeType": {
          "$ref": "#/$defs/budgetScopeType"
        },
        "budgetScopeId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "resolvedBy": {
          "enum": [
            "default_application",
            "runtime_snapshot",
            "control_plane_rule"
          ],
          "description": "Resolved budget scope source. client_provided is not a v2.0.0 contract value."
        },
        "displayName": {
          "description": "display label for frontend only; not a DB or API field contract.",
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "runtimeSnapshotProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeSnapshotId",
        "runtimeSnapshotVersion",
        "contentHash",
        "runtimeState",
        "publishedAt",
        "publishedBy",
        "gatewayInstanceId"
      ],
      "properties": {
        "runtimeSnapshotId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "runtimeSnapshotVersion": {
          "$ref": "#/$defs/positiveInteger"
        },
        "contentHash": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "runtimeState": {
          "$ref": "#/$defs/runtimeProvenanceState"
        },
        "publishedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "publishedBy": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gatewayInstanceId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "legacyHashes": {
          "type": "object",
          "additionalProperties": false,
          "description": "Compatibility/read-model bridge for v1 hash lineage. Not primary RuntimeSnapshot provenance and not a metrics label source.",
          "properties": {
            "configHash": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "securityPolicyHash": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "routingPolicyHash": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "required": [
            "configHash",
            "securityPolicyHash",
            "routingPolicyHash"
          ]
        }
      }
    },
    "domainOutcomeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth",
        "runtime",
        "rateLimit",
        "budget",
        "safety",
        "routing",
        "cache",
        "provider",
        "fallback",
        "streaming",
        "logging"
      ],
      "properties": {
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "passed",
                "invalid_api_key",
                "invalid_app_token",
                "scope_mismatch",
                "not_checked"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "$ref": "#/$defs/runtimeState"
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "rateLimit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "allowed",
                "rate_limited",
                "disabled",
                "error",
                "not_checked"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "allowed",
                "warned",
                "blocked",
                "not_used",
                "not_checked"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "passed",
                "redacted",
                "blocked",
                "not_checked"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "selected",
                "skipped",
                "failed",
                "not_checked"
              ]
            },
            "reason": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "hit",
                "miss",
                "bypassed",
                "error",
                "not_used"
              ]
            },
            "reusedRequestId": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "provider": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "success",
                "timeout",
                "error",
                "unauthorized",
                "not_called"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "not_needed",
                "disabled",
                "success",
                "failed",
                "not_called"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "streaming": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "not_streaming",
                "started",
                "completed",
                "interrupted",
                "cancelled"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        },
        "logging": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "written",
                "failed",
                "deferred",
                "not_called"
              ]
            },
            "code": {
              "$ref": "#/$defs/nullableString"
            }
          }
        }
      }
    },
    "routingSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestedModel",
        "selectedProvider",
        "selectedModel",
        "routingReason"
      ],
      "properties": {
        "requestedModel": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "selectedProvider": {
          "$ref": "#/$defs/nullableString"
        },
        "selectedModel": {
          "$ref": "#/$defs/nullableString"
        },
        "routingReason": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "usageCostLatencySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promptTokens",
        "completionTokens",
        "totalTokens",
        "costMicroUsd",
        "savedCostMicroUsd",
        "gatewayLatencyMs",
        "providerLatencyMs"
      ],
      "properties": {
        "promptTokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "completionTokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "totalTokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "costMicroUsd": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "savedCostMicroUsd": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "gatewayLatencyMs": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "providerLatencyMs": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "safetySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maskingAction",
        "detectorTypes",
        "detectedCount",
        "redactedPreview"
      ],
      "properties": {
        "maskingAction": {
          "enum": [
            "none",
            "redacted",
            "blocked"
          ]
        },
        "detectorTypes": {
          "description": "GateLM-normalized detector type labels only. Values such as organization_name are sanitized categories and must not contain raw detected values, prompt fragments, offsets, or provider/model raw output.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true
        },
        "policyAllowedTypes": {
          "description": "Detector type names explicitly allowed by RuntimeSnapshot policy. Raw values are never included.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true,
          "default": []
        },
        "mandatoryProtectedTypes": {
          "description": "Mandatory detector type names protected regardless of optional PII policy toggles. Raw values are never included.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true,
          "default": []
        },
        "detectedCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "redactedPreview": {
          "description": "Synthetic or redacted-only preview for UI evidence. Must not contain sensitive original values.",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 280
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lastIngestedAt",
        "lastAggregatedAt",
        "source",
        "isStale"
      ],
      "properties": {
        "lastIngestedAt": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "lastAggregatedAt": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "isStale": {
          "type": "boolean"
        }
      }
    },
    "queryBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "defaultTimeRangeApplied",
        "defaultGrainApplied",
        "message"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/queryBudgetState"
        },
        "defaultTimeRangeApplied": {
          "type": "boolean"
        },
        "defaultGrainApplied": {
          "type": "boolean"
        },
        "message": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "requestSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "traceId",
        "startedAt",
        "identity",
        "budgetScope",
        "terminalStatus",
        "httpStatus",
        "errorCode",
        "runtimeSnapshot",
        "outcomes"
      ],
      "properties": {
        "requestId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "traceId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "startedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "completedAt": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "budgetScope": {
          "$ref": "#/$defs/budgetScope"
        },
        "terminalStatus": {
          "$ref": "#/$defs/terminalStatus"
        },
        "httpStatus": {
          "$ref": "#/$defs/httpStatus"
        },
        "errorCode": {
          "$ref": "#/$defs/nullableString"
        },
        "runtimeSnapshot": {
          "anyOf": [
            {
              "$ref": "#/$defs/runtimeSnapshotProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "outcomes": {
          "$ref": "#/$defs/domainOutcomeSummary"
        }
      }
    },
    "employeeChatReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelKind",
        "identity",
        "applicationDisplayName",
        "requestId",
        "terminalStatus",
        "httpStatus",
        "simpleStatus",
        "assistantMessage",
        "streaming",
        "generatedAt"
      ],
      "properties": {
        "modelKind": {
          "const": "employeeChat"
        },
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "applicationDisplayName": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "requestId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "terminalStatus": {
          "$ref": "#/$defs/terminalStatus"
        },
        "httpStatus": {
          "$ref": "#/$defs/httpStatus"
        },
        "simpleStatus": {
          "enum": [
            "ready",
            "running",
            "completed",
            "blocked",
            "failed",
            "cancelled"
          ]
        },
        "assistantMessage": {
          "description": "Employee-visible sanitized response text only.",
          "$ref": "#/$defs/nullableString"
        },
        "streaming": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "outcome"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "outcome": {
              "enum": [
                "not_streaming",
                "started",
                "completed",
                "interrupted",
                "cancelled"
              ]
            }
          }
        },
        "generatedAt": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "requestLogFilterOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "models",
        "budgetScopes"
      ],
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "description": "Low-cardinality model labels for Request Log UI filters. Must not include request IDs, hashes, prompt fragments, or raw provider error text."
        },
        "budgetScopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/budgetScope"
          },
          "description": "Resolved budget scopes available in the Request Log time range."
        }
      }
    },
    "requestLogListReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelKind",
        "items",
        "freshness",
        "queryBudget"
      ],
      "properties": {
        "modelKind": {
          "const": "requestLogList"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requestSummary"
          }
        },
        "filterOptions": {
          "$ref": "#/$defs/requestLogFilterOptions"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "queryBudget": {
          "$ref": "#/$defs/queryBudget"
        }
      }
    },
    "requestDetailReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelKind",
        "request",
        "routing",
        "usage",
        "safety",
        "freshness"
      ],
      "properties": {
        "modelKind": {
          "const": "requestDetail"
        },
        "request": {
          "$ref": "#/$defs/requestSummary"
        },
        "routing": {
          "$ref": "#/$defs/routingSummary"
        },
        "usage": {
          "$ref": "#/$defs/usageCostLatencySummary"
        },
        "safety": {
          "$ref": "#/$defs/safetySummary"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        }
      }
    },
    "dashboardOverviewReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelKind",
        "identity",
        "grain",
        "timeRange",
        "freshness",
        "queryBudget",
        "totals",
        "breakdowns"
      ],
      "properties": {
        "modelKind": {
          "const": "dashboardOverview"
        },
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "grain": {
          "enum": [
            "organization",
            "budget_scope",
            "application",
            "provider_model",
            "safety_outcome",
            "cache_outcome",
            "fallback_outcome"
          ]
        },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "$ref": "#/$defs/dateTime"
            },
            "to": {
              "$ref": "#/$defs/dateTime"
            }
          }
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "queryBudget": {
          "$ref": "#/$defs/queryBudget"
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requestCount",
            "successCount",
            "blockedCount",
            "rateLimitedCount",
            "failedCount",
            "cancelledCount",
            "cacheHitCount",
            "fallbackSuccessCount",
            "costMicroUsd",
            "savedCostMicroUsd"
          ],
          "properties": {
            "requestCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "successCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "blockedCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "rateLimitedCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "failedCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "cancelledCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "cacheHitCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "fallbackSuccessCount": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "costMicroUsd": {
              "$ref": "#/$defs/nonNegativeInteger"
            },
            "savedCostMicroUsd": {
              "$ref": "#/$defs/nonNegativeInteger"
            }
          }
        },
        "breakdowns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "label",
              "requestCount",
              "terminalStatusCounts"
            ],
            "properties": {
              "key": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "label": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "requestCount": {
                "$ref": "#/$defs/nonNegativeInteger"
              },
              "terminalStatusCounts": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "success",
                  "blocked",
                  "rate_limited",
                  "failed",
                  "cancelled"
                ],
                "properties": {
                  "success": {
                    "$ref": "#/$defs/nonNegativeInteger"
                  },
                  "blocked": {
                    "$ref": "#/$defs/nonNegativeInteger"
                  },
                  "rate_limited": {
                    "$ref": "#/$defs/nonNegativeInteger"
                  },
                  "failed": {
                    "$ref": "#/$defs/nonNegativeInteger"
                  },
                  "cancelled": {
                    "$ref": "#/$defs/nonNegativeInteger"
                  }
                }
              }
            }
          }
        }
      }
    },
    "demoScenarioRunnerReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelKind",
        "scenarios",
        "sandboxMode",
        "emergencyStop"
      ],
      "properties": {
        "modelKind": {
          "const": "demoScenarioRunner"
        },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "scenarioId",
              "label",
              "expectedTerminalStatus",
              "expectedOutcomes",
              "enabled"
            ],
            "properties": {
              "scenarioId": {
                "enum": [
                  "safe_request",
                  "exact_cache_hit",
                  "redaction",
                  "safety_block",
                  "rate_limit",
                  "provider_timeout",
                  "provider_error_mock_fallback",
                  "streaming_thin_slice"
                ]
              },
              "label": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "expectedTerminalStatus": {
                "$ref": "#/$defs/terminalStatus"
              },
              "expectedOutcomes": {
                "$ref": "#/$defs/domainOutcomeSummary"
              },
              "enabled": {
                "type": "boolean"
              }
            }
          }
        },
        "sandboxMode": {
          "description": "presenter-control surface. Audience free input is not a v2 core demo path.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "requiresSafetyPrecheck",
            "requiresStrongRateLimit"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requiresSafetyPrecheck": {
              "type": "boolean"
            },
            "requiresStrongRateLimit": {
              "type": "boolean"
            }
          }
        },
        "emergencyStop": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "status"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "status": {
              "enum": [
                "ready",
                "active",
                "disabled"
              ]
            }
          }
        }
      }
    }
  }
