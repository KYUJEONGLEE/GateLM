{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/docs/v2.1.0/schemas/difficulty-evaluation-record.schema.json",
  "title": "GateLM Difficulty Evaluation Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gatelm.difficulty-evaluation-record.v1"
    },
    "datasetVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Difficulty dataset release identifier. Must not contain prompt text."
    },
    "sampleId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-zA-Z0-9._:-]+$",
      "description": "Stable synthetic or generated identifier. Must not encode prompt text or secrets."
    },
    "redactedPrompt": {
      "type": "string",
      "minLength": 0,
      "maxLength": 65536,
      "description": "Safety-masked prompt text. It may be empty when fully redacted. Raw prompt values and secrets are forbidden."
    },
    "expectedCategory": {
      "type": "string",
      "enum": [
        "general",
        "code",
        "translation",
        "summarization",
        "reasoning"
      ]
    },
    "expectedDifficulty": {
      "type": "string",
      "enum": [
        "simple",
        "complex"
      ]
    },
    "labelSource": {
      "type": "string",
      "enum": [
        "human_review",
        "synthetic_fixture"
      ]
    },
    "consentType": {
      "type": "string",
      "enum": [
        "synthetic",
        "internal_manual_review"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "synthetic_fixture",
        "manual_seed"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "ko",
        "mixed",
        "unknown"
      ]
    },
    "redactionVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "labelConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reviewerNote": {
      "type": "string",
      "maxLength": 240,
      "description": "Short safe note without prompt fragments, secrets, or provider errors."
    }
  },
  "required": [
    "schemaVersion",
    "datasetVersion",
    "sampleId",
    "redactedPrompt",
    "expectedCategory",
    "expectedDifficulty",
    "labelSource",
    "consentType",
    "source",
    "language",
    "redactionVersion",
    "createdAt"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "source": {
            "const": "synthetic_fixture"
          }
        },
        "required": [
          "source"
        ]
      },
      "then": {
        "properties": {
          "consentType": {
            "const": "synthetic"
          },
          "labelSource": {
            "const": "synthetic_fixture"
          }
        }
      }
    }
  ]
}
