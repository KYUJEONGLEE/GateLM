{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatelm.local/docs/v2.1.0/schemas/difficulty-independent-dataset-split-manifest.schema.json",
  "title": "GateLM Difficulty Independent Dataset Split Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "gatelm.difficulty-independent-dataset-split-manifest.v1"
    },
    "datasetVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "masterDatasetPath": {
      "const": "docs/v2.1.0/evaluation/difficulty-independent-ood-5000.v1.candidate.jsonl"
    },
    "masterDatasetSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "blindReviewPath": {
      "const": "docs/v2.1.0/reviews/difficulty-independent-ood-5000/difficulty-independent-ood-5000.v1.blind-review.jsonl"
    },
    "blindReviewSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "splitPolicyVersion": {
      "const": "difficulty-independent-ood-family-split.2026-07-18.v1"
    },
    "splitSeed": {
      "type": "integer",
      "const": 2026071803
    },
    "assignmentUnit": {
      "const": "prompt_family"
    },
    "labelState": {
      "const": "labels_pending_human_review"
    },
    "trainingEligible": {
      "const": false
    },
    "dataset1Isolation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataset1Path": {
          "const": "docs/v2.1.0/training/difficulty-model-path-5000.owner-approved.jsonl"
        },
        "usedAsGenerationInput": { "const": false },
        "usedForPostGenerationOverlapAudit": { "const": true },
        "sharedGeneratorModules": {
          "type": "array",
          "maxItems": 0
        },
        "familyNamespace": { "const": "independent2" }
      },
      "required": [
        "dataset1Path",
        "usedAsGenerationInput",
        "usedForPostGenerationOverlapAudit",
        "sharedGeneratorModules",
        "familyNamespace"
      ]
    },
    "standardManifestProjection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "train": { "const": "train" },
        "validation": { "const": "calibration" },
        "test": { "const": "holdout" }
      },
      "required": ["train", "validation", "test"]
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "train": { "$ref": "#/$defs/trainSplit" },
        "validation": { "$ref": "#/$defs/validationSplit" },
        "test": { "$ref": "#/$defs/testSplit" }
      },
      "required": ["train", "validation", "test"]
    },
    "assignments": {
      "type": "array",
      "minItems": 1000,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "promptFamily": {
            "type": "string",
            "pattern": "^independent2\\.[a-z0-9._:-]+$"
          },
          "split": {
            "enum": ["train", "validation", "test"]
          },
          "records": {
            "type": "integer",
            "const": 5
          }
        },
        "required": ["promptFamily", "split", "records"]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schemaVersion",
    "datasetVersion",
    "masterDatasetPath",
    "masterDatasetSha256",
    "blindReviewPath",
    "blindReviewSha256",
    "splitPolicyVersion",
    "splitSeed",
    "assignmentUnit",
    "labelState",
    "trainingEligible",
    "dataset1Isolation",
    "standardManifestProjection",
    "splits",
    "assignments",
    "createdAt"
  ],
  "$defs": {
    "splitBase": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "datasetPath": {
          "type": "string",
          "pattern": "^docs/v2\\.1\\.0/evaluation/difficulty-independent-ood-5000\\.v1\\.(train|validation|test)\\.jsonl$"
        },
        "datasetSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "records": { "type": "integer" },
        "families": { "type": "integer" },
        "purpose": { "type": "string" }
      },
      "required": ["datasetPath", "datasetSha256", "records", "families", "purpose"]
    },
    "trainSplit": {
      "allOf": [
        { "$ref": "#/$defs/splitBase" },
        {
          "properties": {
            "datasetPath": { "const": "docs/v2.1.0/evaluation/difficulty-independent-ood-5000.v1.train.jsonl" },
            "records": { "const": 3000 },
            "families": { "const": 600 },
            "purpose": { "const": "future_weight_fit_after_human_approval" }
          }
        }
      ]
    },
    "validationSplit": {
      "allOf": [
        { "$ref": "#/$defs/splitBase" },
        {
          "properties": {
            "datasetPath": { "const": "docs/v2.1.0/evaluation/difficulty-independent-ood-5000.v1.validation.jsonl" },
            "records": { "const": 1000 },
            "families": { "const": 200 },
            "purpose": { "const": "future_model_selection_after_human_approval" }
          }
        }
      ]
    },
    "testSplit": {
      "allOf": [
        { "$ref": "#/$defs/splitBase" },
        {
          "properties": {
            "datasetPath": { "const": "docs/v2.1.0/evaluation/difficulty-independent-ood-5000.v1.test.jsonl" },
            "records": { "const": 1000 },
            "families": { "const": 200 },
            "purpose": { "const": "untouched_final_evaluation_after_human_approval" }
          }
        }
      ]
    }
  }
}
