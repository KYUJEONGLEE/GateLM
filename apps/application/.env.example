# GateLM Application server env
#
# The bundled GateLM demo server script loads the repository root `.env`.
# Copy this file to `.env.local` only when running `@gatelm/application`
# by itself from this package directory.
# Do not commit `.env.local`.
# Do not use NEXT_PUBLIC_ for Gateway credentials.

GATELM_WEB_CUSTOMER_DEMO_MODE=gateway
GATELM_GATEWAY_BASE_URL=http://localhost:8080
GATELM_GATEWAY_API_KEY=replace_with_project_api_key

# Optional multi-project chat profiles. Keep this as a single line and keep API keys server-side only.
# GATELM_APPLICATION_CHAT_PROFILES='[{"id":"customer-support","label":"Customer Support","projectId":"00000000-0000-4000-8000-000000000200","apiKey":"gsk_live_replace_me"},{"id":"dev-tools","label":"Dev Tools","projectId":"00000000-0000-4000-8000-000000000201","apiKey":"gsk_live_replace_me"}]'

GATELM_APPLICATION_CHAT_MAX_TOKENS=2048
GATELM_APPLICATION_CHAT_STREAMING_ENABLED=true
