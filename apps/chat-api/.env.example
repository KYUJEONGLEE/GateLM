CHAT_API_PORT=3003
DATABASE_URL=postgresql://gatelm:gatelm@localhost:5432/gatelm?schema=public
TENANT_CHAT_ACCESS_JWT_SECRET=replace-with-a-strong-local-access-signing-secret
TENANT_CHAT_INTENT_SECRET=replace-with-a-strong-local-invitation-intent-secret
TENANT_CHAT_WEB_SERVICE_TOKEN=replace-with-a-strong-local-web-service-token
TENANT_CHAT_CONTROL_PLANE_BASE_URL=http://localhost:3001
