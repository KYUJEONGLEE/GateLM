RAG_QUERY_EMBEDDING_BINDING_HMAC_KEYS_FILE=/run/secrets/tenant-chat-rag-query/binding-hmac-keys.json
RAG_QUERY_EMBEDDING_TIMEOUT_MS=10000
RAG_TOP_K=6
RAG_MIN_SCORE=0.30
RAG_CONTEXT_MAX_TOKENS=6000
RAG_PROMPT_VERSION=1
RAG_RETRIEVAL_QUERY_MAX_UTF8_BYTES=8192
TENANT_CHAT_WORKLOAD_ACTIVE_KID=tenant-chat-local-1
TENANT_CHAT_WORKLOAD_SIGNING_JWK_FILE=/run/secrets/tenant-chat/signing.jwk.json
TENANT_CHAT_BINDING_HMAC_KEYS_FILE=/run/secrets/tenant-chat/binding-hmac-keys.json
TENANT_CHAT_CONTENT_KEYS_FILE=/run/secrets/tenant-chat/content-keys.json
TENANT_CHAT_CONTROL_PLANE_TIMEOUT_MS=1500
TENANT_CHAT_GATEWAY_ADMISSION_TIMEOUT_MS=2000
TENANT_CHAT_GATEWAY_CANCEL_TIMEOUT_MS=2000
TENANT_CHAT_GATEWAY_COMPLETION_TIMEOUT_MS=130000
TENANT_CHAT_GATEWAY_JSON_MAX_BYTES=65536
TENANT_CHAT_GATEWAY_REQUEST_MAX_BYTES=4194304
TENANT_CHAT_GATEWAY_SSE_FRAME_MAX_BYTES=65536
TENANT_CHAT_GATEWAY_STREAM_MAX_BYTES=8388608
TENANT_CHAT_HISTORY_RETENTION_DAYS=30
TENANT_CHAT_RETENTION_BATCH_SIZE=50
TENANT_CHAT_RETENTION_INTERVAL_MS=60000
TENANT_CHAT_ASSISTANT_MAX_BYTES=1048576
TENANT_CHAT_MAX_ATTACHMENTS_PER_TURN=4
