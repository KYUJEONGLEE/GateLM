{
  "name": "@gatelm/chat-api",
  "private": true,
  "version": "0.1.0",
  "description": "GateLM Tenant Chat private auth and session API",
  "scripts": {
    "predev": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "dev": "node --env-file=../../.env node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start": "node dist/main.js",
    "prebuild": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "build": "nest build",
    "presmoke:execution": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "smoke:execution": "ts-node -r tsconfig-paths/register src/execution/smoke.ts",
    "presmoke:content": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "smoke:content": "ts-node -r tsconfig-paths/register src/content/smoke.ts",
    "pretypecheck": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @gatelm/tenant-content-crypto build && pnpm --filter @gatelm/rag-config build",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@gatelm/rag-config": "workspace:*",
    "@gatelm/tenant-content-crypto": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "ajv": "^8.17.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.22.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
