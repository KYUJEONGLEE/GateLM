generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceStatus {
  ACTIVE
  DRAFT
  DISABLED
  ARCHIVED
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DISABLED
}

enum RuntimeConfigPublishState {
  DRAFT
  ACTIVE
  SUPERSEDED
  ROLLED_BACK
}

enum ProviderConnectionStatus {
  ACTIVE
  DISABLED
  DEGRADED
}

model Tenant {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  status         ResourceStatus @default(ACTIVE)
  authzVersion   Int            @default(1)
  totalBudgetUsd Decimal?       @default(1000) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  projects                        Project[]
  applications                    Application[]
  providerConnections             ProviderConnection[]
  providerCredentials             ProviderCredential[]
  applicationProviderConnections  ApplicationProviderConnection[]
  apiKeys                         GatewayApiKey[]
  appTokens                       AppToken[]
  runtimeConfigs                  RuntimeConfig[]
  runtimeSnapshots                RuntimeSnapshot[]
  activeSnapshots                 ActiveRuntimeSnapshot[]
  budgetLedgerEntries             BudgetLedgerEntry[]
  budgetQuotas                    BudgetQuota[]
  budgetAuditLogs                 BudgetAuditLog[]
  notificationEvents              NotificationEvent[]
  teams                           Team[]
  projectTeamAssignments          ProjectTeamAssignment[]
  tenantMemberships               TenantMembership[]
  tenantAdmins                    TenantAdmin[]
  projectAdmins                   ProjectAdmin[]
  projectAdminInvitations         ProjectAdminInvitation[]
  employees                       Employee[]
  projectEmployeeAssignments      ProjectEmployeeAssignment[]
  conversations                   Conversation[]
  chatMessages                    ChatMessage[]
  selectedTenantChatSessions      TenantChatSession[]              @relation("TenantChatSelectedTenant")
  tenantChatPricingCatalogs       TenantChatPricingCatalog[]
  tenantChatRuntimeConfigs        TenantChatRuntimeConfig[]
  tenantChatRuntimeSnapshots      TenantChatRuntimeSnapshot[]
  tenantChatActiveRuntimeSnapshot TenantChatActiveRuntimeSnapshot?
  tenantChatRequestAdmissions     TenantChatRequestAdmission[]
  tenantChatUserTokenPeriods      TenantChatUserTokenPeriod[]
  tenantChatTenantCostPeriods     TenantChatTenantCostPeriod[]
  tenantChatProviderAttempts      TenantChatProviderAttempt[]
  tenantChatUsageLedgerEntries    TenantChatUsageLedgerEntry[]
  tenantChatInvocationOutbox      TenantChatInvocationOutbox[]
  tenantChatInvocationLogs        TenantChatInvocationLog[]
  tenantChatContentKeyState       TenantChatContentKeyState?
  tenantChatContentKeys           TenantChatContentKey[]
  tenantChatConversations         TenantChatConversation[]
  dashboardRollupDirtyBuckets     DashboardRollupDirtyBucket[]
  dashboardRollupBucketStates     DashboardRollupBucketState[]
  dashboardRollupTotals           DashboardRollupTotal[]
  dashboardRollupDimensions       DashboardRollupDimension[]
  employeeUsageRollups            EmployeeUsageRollup[]
  employeeCostPolicies            TenantEmployeeCostPolicy[]
  employeeCostPolicyAudits        TenantEmployeeCostPolicyAudit[]
  employeeCostLedgerRollout       TenantEmployeeCostLedgerRollout?
  employeeCostPeriods             TenantEmployeeCostPeriod[]
  ragKnowledgeBases               RagKnowledgeBase[]
  ragDocuments                    RagDocument[]
  ragDocumentIndexes              RagDocumentIndex[]
  ragChunks                       RagChunk[]
  ragJobs                         RagJob[]
  ragEmbeddingUsages              RagEmbeddingUsage[]

  @@map("tenants")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String
  name              String?
  passwordHash      String?
  authProvider      String    @default("local")
  actorAuthzVersion Int       @default(1)
  status            String    @default("pending_email_verification")
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  emailVerificationCodes      EmailVerificationCode[]
  authSessions                AuthSession[]
  oauthAccounts               OAuthAccount[]
  tenantMemberships           TenantMembership[]
  tenantAdmins                TenantAdmin[]
  projectAdmins               ProjectAdmin[]
  sentProjectAdminInvitations ProjectAdminInvitation[]     @relation("ProjectAdminInvitationInviter")
  employees                   Employee[]
  tenantChatSessions          TenantChatSession[]
  tenantChatRequestAdmissions TenantChatRequestAdmission[]
  tenantChatUserTokenPeriods  TenantChatUserTokenPeriod[]
  tenantChatInvocationLogs    TenantChatInvocationLog[]
  tenantChatConversations     TenantChatConversation[]
  uploadedRagDocuments        RagDocument[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model EmailVerificationCode {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  codeHash           String
  failedAttemptCount Int       @default(0)
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  sessionTokenHash String
  kind             String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionTokenHash])
  @@index([userId, kind, revokedAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model TenantChatSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  selectedTenantId String?   @db.Uuid
  deviceIdHash     String
  sessionVersion   Int       @default(1)
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedTenant Tenant?                  @relation("TenantChatSelectedTenant", fields: [selectedTenantId], references: [id], onDelete: SetNull)
  refreshTokens  TenantChatRefreshToken[]

  @@index([userId, revokedAt])
  @@index([selectedTenantId, revokedAt])
  @@index([expiresAt])
  @@map("tenant_chat_sessions")
}

model TenantChatRefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  sessionId         String    @db.Uuid
  familyId          String    @db.Uuid
  tokenHash         String    @unique
  parentTokenId     String?   @db.Uuid
  replacedByTokenId String?   @db.Uuid
  expiresAt         DateTime
  consumedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  session TenantChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, familyId])
  @@index([familyId, revokedAt])
  @@index([expiresAt])
  @@map("tenant_chat_refresh_tokens")
}

model OAuthAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  provider        String
  providerSubject String
  email           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([email])
  @@map("oauth_accounts")
}

model TenantMembership {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  role      String
  status    String    @default("active")
  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, role, status])
  @@map("tenant_memberships")
}

model TenantAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_admins")
}

model ProjectAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("project_admins")
}

model ProjectAdminInvitation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  projectId       String    @db.Uuid
  email           String
  name            String
  tokenHash       String
  status          String    @default("pending")
  invitedByUserId String?   @db.Uuid
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedByUser User?   @relation("ProjectAdminInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([tokenHash])
  @@index([tenantId, status])
  @@index([projectId, status])
  @@index([email, status])
  @@map("project_admin_invitations")
}

model Project {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  name           String
  description    String?
  status         ResourceStatus @default(ACTIVE)
  totalBudgetUsd Decimal?       @default(100) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant                         Tenant                          @relation(fields: [tenantId], references: [id])
  applications                   Application[]
  providerConnections            ProviderConnection[]
  applicationProviderConnections ApplicationProviderConnection[]
  apiKeys                        GatewayApiKey[]
  appTokens                      AppToken[]
  runtimeConfigs                 RuntimeConfig[]
  runtimeSnapshots               RuntimeSnapshot[]
  activeSnapshots                ActiveRuntimeSnapshot[]
  budgetLedgerEntries            BudgetLedgerEntry[]
  budgetAuditLogs                BudgetAuditLog[]
  notificationEvents             NotificationEvent[]
  projectTeamAssignments         ProjectTeamAssignment[]
  projectAdmins                  ProjectAdmin[]
  projectAdminInvitations        ProjectAdminInvitation[]
  projectEmployeeAssignments     ProjectEmployeeAssignment[]
  conversations                  Conversation[]
  chatMessages                   ChatMessage[]

  @@index([tenantId])
  @@map("projects")
}

model Team {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  projectTeamAssignments ProjectTeamAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("teams")
}

model ProjectTeamAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  projectId String   @db.Uuid
  teamId    String   @db.Uuid
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([tenantId])
  @@index([projectId])
  @@index([teamId])
  @@map("project_team_assignments")
}

model Employee {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @db.Uuid
  userId              String?   @db.Uuid
  email               String
  name                String?
  department          String?
  status              String    @default("staged")
  invitationStatus    String    @default("not_sent")
  invitationTokenHash String?   @unique
  invitationExpiresAt DateTime?
  invitationRevokedAt DateTime?
  invitedAt           DateTime?
  acceptedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  tenant                      Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                        User?                           @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectAssignments          ProjectEmployeeAssignment[]
  tenantChatRequestAdmissions TenantChatRequestAdmission[]
  tenantChatInvocationLogs    TenantChatInvocationLog[]
  usageRollups                EmployeeUsageRollup[]
  costPolicy                  TenantEmployeeCostPolicy?
  costPolicyAudits            TenantEmployeeCostPolicyAudit[]
  costPeriods                 TenantEmployeeCostPeriod[]
  costReservations            TenantEmployeeCostReservation[]

  @@unique([id, tenantId], map: "employees_identity_tenant_key")
  @@index([tenantId, status])
  @@index([tenantId, invitationStatus])
  @@index([tenantId, department])
  @@index([userId])
  @@map("employees")
}

model ProjectEmployeeAssignment {
  id                         String   @id @default(uuid()) @db.Uuid
  tenantId                   String   @db.Uuid
  projectId                  String   @db.Uuid
  employeeId                 String   @db.Uuid
  monthlyBudgetLimitMicroUsd BigInt   @default(0)
  warningThresholdPercent    Int      @default(80)
  policy                     Json     @default("{}")
  status                     String   @default("active")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@index([tenantId])
  @@index([projectId, status])
  @@index([employeeId, status])
  @@map("project_employee_assignments")
}

model TenantEmployeeCostPolicy {
  tenantId                String   @map("tenant_id") @db.Uuid
  employeeId              String   @map("employee_id") @db.Uuid
  dailyEnabled            Boolean  @default(false) @map("daily_enabled")
  dailyLimitMicroUsd      BigInt   @default(0) @map("daily_limit_micro_usd")
  weeklyEnabled           Boolean  @default(false) @map("weekly_enabled")
  weeklyLimitMicroUsd     BigInt   @default(0) @map("weekly_limit_micro_usd")
  currency                String   @default("USD")
  periodTimezone          String   @default("Asia/Seoul") @map("period_timezone")
  warningThresholdPercent Int      @default(80) @map("warning_threshold_percent")
  enforcementMode         String   @default("monitor") @map("enforcement_mode")
  version                 Int      @default(1)
  updatedBy               String   @map("updated_by") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenant_employee_cost_policies_tenant_fkey")
  employee Employee                        @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: NoAction, map: "tenant_employee_cost_policies_employee_tenant_fkey")
  audits   TenantEmployeeCostPolicyAudit[]

  @@id([tenantId, employeeId])
  @@unique([employeeId, tenantId], map: "tenant_employee_cost_policies_employee_tenant_key")
  @@index([tenantId, enforcementMode], map: "tenant_employee_cost_policies_mode_idx")
  @@map("tenant_employee_cost_policies")
}

model TenantEmployeeCostPolicyAudit {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  actorId        String   @map("actor_id") @db.Uuid
  policyVersion  Int      @map("policy_version")
  action         String   @default("policy_updated")
  previousPolicy Json     @default("{}") @map("previous_policy")
  nextPolicy     Json     @map("next_policy")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenant_employee_cost_policy_audits_tenant_fkey")
  employee Employee                 @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: NoAction, map: "tenant_employee_cost_policy_audits_employee_tenant_fkey")
  policy   TenantEmployeeCostPolicy @relation(fields: [tenantId, employeeId], references: [tenantId, employeeId], onDelete: Restrict, onUpdate: NoAction, map: "tenant_employee_cost_policy_audits_policy_fkey")

  @@unique([tenantId, employeeId, policyVersion], map: "tenant_employee_cost_policy_audits_version_key")
  @@index([tenantId, createdAt], map: "tenant_employee_cost_policy_audits_tenant_created_idx")
  @@index([tenantId, employeeId, createdAt], map: "tenant_employee_cost_policy_audits_employee_created_idx")
  @@map("tenant_employee_cost_policy_audits")
}

model TenantEmployeeCostLedgerRollout {
  tenantId                      String    @id @map("tenant_id") @db.Uuid
  mode                          String    @default("off")
  activationBoundaryAt          DateTime? @map("activation_boundary_at") @db.Timestamptz(6)
  projectApplicationCoveredFrom DateTime? @map("project_application_covered_from") @db.Timestamptz(6)
  tenantChatCoveredFrom         DateTime? @map("tenant_chat_covered_from") @db.Timestamptz(6)
  coverageInvalidatedAt         DateTime? @map("coverage_invalidated_at") @db.Timestamptz(6)
  coverageErrorCode             String?   @map("coverage_error_code")
  version                       BigInt    @default(1)
  updatedByKind                 String    @map("updated_by_kind")
  updatedBy                     String    @map("updated_by")
  createdAt                     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant                                 @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_rollouts_tenant_fkey")
  audits       TenantEmployeeCostLedgerRolloutAudit[]
  periods      TenantEmployeeCostPeriod[]
  reservations TenantEmployeeCostReservation[]

  @@index([mode, activationBoundaryAt], map: "employee_cost_rollouts_mode_activation_idx")
  @@map("tenant_employee_cost_ledger_rollouts")
}

model TenantEmployeeCostLedgerRolloutAudit {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  actorKind       String   @map("actor_kind")
  actorId         String   @map("actor_id")
  rolloutVersion  BigInt   @map("rollout_version")
  action          String
  previousRollout Json     @default("{}") @map("previous_rollout")
  nextRollout     Json     @map("next_rollout")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rollout TenantEmployeeCostLedgerRollout @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_rollout_audits_rollout_fkey")

  @@unique([tenantId, rolloutVersion], map: "employee_cost_rollout_audits_version_key")
  @@index([tenantId, createdAt(sort: Desc)], map: "employee_cost_rollout_audits_tenant_created_idx")
  @@map("tenant_employee_cost_ledger_rollout_audits")
}

model TenantEmployeeCostPeriod {
  tenantId                   String   @map("tenant_id") @db.Uuid
  employeeId                 String   @map("employee_id") @db.Uuid
  periodKind                 String   @map("period_kind")
  periodStart                DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd                  DateTime @map("period_end") @db.Timestamptz(6)
  periodTimezone             String   @map("period_timezone")
  currency                   String   @default("USD") @db.Char(3)
  createdPolicyVersion       Int      @default(0) @map("created_policy_version")
  lastEvaluatedPolicyVersion Int      @default(0) @map("last_evaluated_policy_version")
  confirmedCostMicroUsd      BigInt   @default(0) @map("confirmed_cost_micro_usd")
  reservedCostMicroUsd       BigInt   @default(0) @map("reserved_cost_micro_usd")
  unconfirmedCostMicroUsd    BigInt   @default(0) @map("unconfirmed_cost_micro_usd")
  state                      String   @default("not_configured")
  version                    BigInt   @default(1)
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_periods_tenant_fkey")
  rollout          TenantEmployeeCostLedgerRollout @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_periods_rollout_fkey")
  employee         Employee                        @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_periods_employee_tenant_fkey")
  dayReservations  TenantEmployeeCostReservation[] @relation("EmployeeCostReservationDayPeriod")
  weekReservations TenantEmployeeCostReservation[] @relation("EmployeeCostReservationWeekPeriod")

  @@id([tenantId, employeeId, periodKind, periodStart, currency], map: "employee_cost_periods_pkey")
  @@index([tenantId, employeeId, periodKind, periodEnd(sort: Desc)], map: "employee_cost_periods_tenant_employee_current_idx")
  @@index([tenantId, periodKind, state, periodEnd(sort: Desc)], map: "employee_cost_periods_tenant_state_idx")
  @@map("tenant_employee_cost_periods")
}

model TenantEmployeeCostReservation {
  reservationId           String    @id @default(uuid()) @map("reservation_id") @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  employeeId              String    @map("employee_id") @db.Uuid
  surface                 String
  requestId               String    @map("request_id")
  dayPeriodKind           String    @default("day") @map("day_period_kind")
  dayPeriodStart          DateTime  @map("day_period_start") @db.Timestamptz(6)
  weekPeriodKind          String    @default("week") @map("week_period_kind")
  weekPeriodStart         DateTime  @map("week_period_start") @db.Timestamptz(6)
  currency                String    @default("USD") @db.Char(3)
  pinnedPolicyVersion     Int       @default(0) @map("pinned_policy_version")
  enforcementMode         String    @map("enforcement_mode")
  dailyEnabled            Boolean   @map("daily_enabled")
  dailyLimitMicroUsd      BigInt    @map("daily_limit_micro_usd")
  dailyWarningMicroUsd    BigInt    @map("daily_warning_micro_usd")
  dailyState              String    @map("daily_state")
  weeklyEnabled           Boolean   @map("weekly_enabled")
  weeklyLimitMicroUsd     BigInt    @map("weekly_limit_micro_usd")
  weeklyWarningMicroUsd   BigInt    @map("weekly_warning_micro_usd")
  weeklyState             String    @map("weekly_state")
  enforcementOutcome      String    @map("enforcement_outcome")
  pricingRuleId           String    @map("pricing_rule_id")
  pricingVersion          String    @map("pricing_version")
  estimateVersion         String    @map("estimate_version")
  reservedCostMicroUsd    BigInt    @default(0) @map("reserved_cost_micro_usd")
  confirmedCostMicroUsd   BigInt    @default(0) @map("confirmed_cost_micro_usd")
  unconfirmedCostMicroUsd BigInt    @default(0) @map("unconfirmed_cost_micro_usd")
  state                   String    @default("reserved")
  ledgerVersion           BigInt    @default(0) @map("ledger_version")
  reservedAt              DateTime  @map("reserved_at") @db.Timestamptz(6)
  usagePendingAt          DateTime? @map("usage_pending_at") @db.Timestamptz(6)
  terminalAt              DateTime? @map("terminal_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  rollout          TenantEmployeeCostLedgerRollout     @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict, onUpdate: Restrict, map: "employee_cost_reservations_rollout_fkey")
