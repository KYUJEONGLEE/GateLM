  document      RagDocument?     @relation(fields: [documentId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: NoAction, map: "rag_jobs_document_tenant_fkey")

  @@unique([id, tenantId], map: "rag_jobs_id_tenant_key")
