generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceStatus {
  ACTIVE
  DRAFT
  DISABLED
  ARCHIVED
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DISABLED
}

enum RuntimeConfigPublishState {
  DRAFT
  ACTIVE
  SUPERSEDED
  ROLLED_BACK
}

enum ProviderConnectionStatus {
  ACTIVE
  DISABLED
  DEGRADED
}

model Tenant {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  status         ResourceStatus @default(ACTIVE)
  authzVersion   Int            @default(1)
  totalBudgetUsd Decimal?       @default(1000) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  projects                        Project[]
  applications                    Application[]
  providerConnections             ProviderConnection[]
  providerCredentials             ProviderCredential[]
  applicationProviderConnections  ApplicationProviderConnection[]
  apiKeys                         GatewayApiKey[]
  appTokens                       AppToken[]
  runtimeConfigs                  RuntimeConfig[]
  runtimeSnapshots                RuntimeSnapshot[]
  activeSnapshots                 ActiveRuntimeSnapshot[]
  budgetLedgerEntries             BudgetLedgerEntry[]
  budgetQuotas                    BudgetQuota[]
  budgetAuditLogs                 BudgetAuditLog[]
  notificationEvents              NotificationEvent[]
  teams                           Team[]
  projectTeamAssignments          ProjectTeamAssignment[]
  tenantMemberships               TenantMembership[]
  tenantAdmins                    TenantAdmin[]
  projectAdmins                   ProjectAdmin[]
  projectAdminInvitations         ProjectAdminInvitation[]
  employees                       Employee[]
  projectEmployeeAssignments      ProjectEmployeeAssignment[]
  conversations                   Conversation[]
  chatMessages                    ChatMessage[]
  selectedTenantChatSessions      TenantChatSession[]              @relation("TenantChatSelectedTenant")
  tenantChatPricingCatalogs       TenantChatPricingCatalog[]
  tenantChatRuntimeConfigs        TenantChatRuntimeConfig[]
  tenantChatRuntimeSnapshots      TenantChatRuntimeSnapshot[]
  tenantChatActiveRuntimeSnapshot TenantChatActiveRuntimeSnapshot?
  tenantChatRequestAdmissions     TenantChatRequestAdmission[]
  tenantChatUserTokenPeriods      TenantChatUserTokenPeriod[]
  tenantChatTenantCostPeriods     TenantChatTenantCostPeriod[]
  tenantChatProviderAttempts      TenantChatProviderAttempt[]
  tenantChatUsageLedgerEntries    TenantChatUsageLedgerEntry[]
  tenantChatInvocationOutbox      TenantChatInvocationOutbox[]
  tenantChatInvocationLogs        TenantChatInvocationLog[]
  dashboardRollupDirtyBuckets     DashboardRollupDirtyBucket[]
  dashboardRollupBucketStates     DashboardRollupBucketState[]
  dashboardRollupTotals           DashboardRollupTotal[]
  dashboardRollupDimensions       DashboardRollupDimension[]
  employeeUsageRollups            EmployeeUsageRollup[]

  @@map("tenants")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String
  name              String?
  passwordHash      String?
  authProvider      String    @default("local")
  actorAuthzVersion Int       @default(1)
  status            String    @default("pending_email_verification")
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  emailVerificationCodes      EmailVerificationCode[]
  authSessions                AuthSession[]
  oauthAccounts               OAuthAccount[]
  tenantMemberships           TenantMembership[]
  tenantAdmins                TenantAdmin[]
  projectAdmins               ProjectAdmin[]
  sentProjectAdminInvitations ProjectAdminInvitation[]     @relation("ProjectAdminInvitationInviter")
  employees                   Employee[]
  tenantChatSessions          TenantChatSession[]
  tenantChatRequestAdmissions TenantChatRequestAdmission[]
  tenantChatUserTokenPeriods  TenantChatUserTokenPeriod[]
  tenantChatInvocationLogs    TenantChatInvocationLog[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model EmailVerificationCode {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  codeHash           String
  failedAttemptCount Int       @default(0)
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  sessionTokenHash String
  kind             String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionTokenHash])
  @@index([userId, kind, revokedAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model TenantChatSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  selectedTenantId String?   @db.Uuid
  deviceIdHash     String
  sessionVersion   Int       @default(1)
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedTenant Tenant?                  @relation("TenantChatSelectedTenant", fields: [selectedTenantId], references: [id], onDelete: SetNull)
  refreshTokens  TenantChatRefreshToken[]

  @@index([userId, revokedAt])
  @@index([selectedTenantId, revokedAt])
  @@index([expiresAt])
  @@map("tenant_chat_sessions")
}

model TenantChatRefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  sessionId         String    @db.Uuid
  familyId          String    @db.Uuid
  tokenHash         String    @unique
  parentTokenId     String?   @db.Uuid
  replacedByTokenId String?   @db.Uuid
  expiresAt         DateTime
  consumedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  session TenantChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, familyId])
  @@index([familyId, revokedAt])
  @@index([expiresAt])
  @@map("tenant_chat_refresh_tokens")
}

model OAuthAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  provider        String
  providerSubject String
  email           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([email])
  @@map("oauth_accounts")
}

model TenantMembership {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  role      String
  status    String    @default("active")
  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, role, status])
  @@map("tenant_memberships")
}

model TenantAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_admins")
}

model ProjectAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("project_admins")
}

model ProjectAdminInvitation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  projectId       String    @db.Uuid
  email           String
  name            String
  tokenHash       String
  status          String    @default("pending")
  invitedByUserId String?   @db.Uuid
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedByUser User?   @relation("ProjectAdminInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([tokenHash])
  @@index([tenantId, status])
  @@index([projectId, status])
  @@index([email, status])
  @@map("project_admin_invitations")
}

model Project {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  name           String
  description    String?
  status         ResourceStatus @default(ACTIVE)
  totalBudgetUsd Decimal?       @default(100) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant                         Tenant                          @relation(fields: [tenantId], references: [id])
  applications                   Application[]
  providerConnections            ProviderConnection[]
  applicationProviderConnections ApplicationProviderConnection[]
  apiKeys                        GatewayApiKey[]
  appTokens                      AppToken[]
  runtimeConfigs                 RuntimeConfig[]
  runtimeSnapshots               RuntimeSnapshot[]
  activeSnapshots                ActiveRuntimeSnapshot[]
  budgetLedgerEntries            BudgetLedgerEntry[]
  budgetAuditLogs                BudgetAuditLog[]
  notificationEvents             NotificationEvent[]
  projectTeamAssignments         ProjectTeamAssignment[]
  projectAdmins                  ProjectAdmin[]
  projectAdminInvitations        ProjectAdminInvitation[]
  projectEmployeeAssignments     ProjectEmployeeAssignment[]
  conversations                  Conversation[]
  chatMessages                   ChatMessage[]

  @@index([tenantId])
  @@map("projects")
}

model Team {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  projectTeamAssignments ProjectTeamAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("teams")
}

model ProjectTeamAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  projectId String   @db.Uuid
  teamId    String   @db.Uuid
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([tenantId])
  @@index([projectId])
  @@index([teamId])
  @@map("project_team_assignments")
}

model Employee {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @db.Uuid
  userId              String?   @db.Uuid
  email               String
  name                String?
  department          String?
  status              String    @default("staged")
  invitationStatus    String    @default("not_sent")
  invitationTokenHash String?   @unique
  invitationExpiresAt DateTime?
  invitationRevokedAt DateTime?
  invitedAt           DateTime?
  acceptedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                        User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectAssignments          ProjectEmployeeAssignment[]
  tenantChatRequestAdmissions TenantChatRequestAdmission[]
  tenantChatInvocationLogs    TenantChatInvocationLog[]
  usageRollups                EmployeeUsageRollup[]

  @@unique([id, tenantId], map: "employees_identity_tenant_key")
  @@index([tenantId, status])
  @@index([tenantId, invitationStatus])
  @@index([tenantId, department])
  @@index([userId])
  @@map("employees")
}

model ProjectEmployeeAssignment {
  id                         String   @id @default(uuid()) @db.Uuid
  tenantId                   String   @db.Uuid
  projectId                  String   @db.Uuid
  employeeId                 String   @db.Uuid
  monthlyBudgetLimitMicroUsd BigInt   @default(0)
  warningThresholdPercent    Int      @default(80)
  policy                     Json     @default("{}")
  status                     String   @default("active")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@index([tenantId])
  @@index([projectId, status])
  @@index([employeeId, status])
  @@map("project_employee_assignments")
}

model Application {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid
  projectId          String         @db.Uuid
  name               String
  description        String?
  status             ResourceStatus @default(ACTIVE)
  budgetLimitUsd     Decimal?       @db.Decimal(12, 2)
  budgetLimitMode    String         @default("FIXED")
  budgetLimitPercent Decimal?       @db.Decimal(5, 2)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant              Tenant                          @relation(fields: [tenantId], references: [id])
  project             Project                         @relation(fields: [projectId], references: [id])
  appTokens           AppToken[]
  providerConnections ApplicationProviderConnection[]
  runtimeConfigs      RuntimeConfig[]
  runtimeSnapshots    RuntimeSnapshot[]
  activeSnapshots     ActiveRuntimeSnapshot[]
  budgetLedgerEntries BudgetLedgerEntry[]
  budgetAuditLogs     BudgetAuditLog[]
  notificationEvents  NotificationEvent[]
  conversations       Conversation[]
  chatMessages        ChatMessage[]

  @@index([tenantId])
  @@index([projectId])
  @@map("applications")
}

model ProviderConnection {
  id               String                   @id @default(uuid()) @db.Uuid
  tenantId         String                   @db.Uuid
  projectId        String?                  @db.Uuid
  provider         String
  displayName      String
  status           ProviderConnectionStatus @default(ACTIVE)
  baseUrl          String
  timeoutMs        Int                      @default(30000)
  secretRef        String?
  credentialPrefix String?
  credentialLast4  String?
  resolver         String                   @default("none")
  providerConfig   Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  tenant                         Tenant                          @relation(fields: [tenantId], references: [id])
  project                        Project?                        @relation(fields: [projectId], references: [id])
  applicationProviderConnections ApplicationProviderConnection[]
  providerCredentials            ProviderCredential[]

  @@unique([projectId, provider])
  @@index([tenantId])
  @@map("provider_connections")
}

model ProviderCredential {
  id                   String           @id @default(uuid()) @db.Uuid
  tenantId             String           @db.Uuid
  providerConnectionId String           @db.Uuid
  credentialRefId      String
  status               CredentialStatus @default(ACTIVE)
  encryptedValue       String
  encryptionNonce      String
  encryptionTag        String
  encryptionKeyVersion String           @default("v1")
  credentialPrefix     String?
  credentialLast4      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  rotatedAt            DateTime?
  revokedAt            DateTime?

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  providerConnection ProviderConnection @relation(fields: [providerConnectionId], references: [id], onDelete: Cascade)

  @@unique([credentialRefId])
  @@index([tenantId])
  @@index([providerConnectionId])
  @@index([status])
  @@map("provider_credentials")
}

model ApplicationProviderConnection {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  projectId            String   @db.Uuid
  applicationId        String   @db.Uuid
  providerConnectionId String   @db.Uuid
  createdAt            DateTime @default(now())

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  project            Project            @relation(fields: [projectId], references: [id])
  application        Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  providerConnection ProviderConnection @relation(fields: [providerConnectionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, providerConnectionId])
  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([providerConnectionId])
  @@map("application_provider_connections")
}

model ProviderPreset {
  providerKey        String         @id
  displayName        String
  adapterType        String
  baseUrl            String
  modelsEndpointPath String         @default("/models")
  credentialRequired Boolean        @default(true)
  defaultResolver    String         @default("environment")
  defaultTimeoutMs   Int            @default(30000)
  status             ResourceStatus @default(ACTIVE)
  sortOrder          Int            @default(100)
  providerConfig     Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status, sortOrder])
  @@map("provider_presets")
}

model GatewayApiKey {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([prefix])
  @@map("gateway_api_keys")
}

model AppToken {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  applicationId String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  project     Project     @relation(fields: [projectId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([prefix])
  @@map("app_tokens")
}

model BudgetLedgerEntry {
  requestId       String    @id @map("request_id")
  tenantId        String    @map("tenant_id") @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  applicationId   String?   @map("application_id") @db.Uuid
  budgetScopeType String    @map("budget_scope_type")
  budgetScopeId   String    @map("budget_scope_id")
  monthStart      DateTime  @map("month_start") @db.Date
  costMicroUsd    BigInt    @default(0) @map("cost_micro_usd")
  source          String    @default("request_log")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([tenantId, budgetScopeType, budgetScopeId, monthStart])
  @@index([tenantId, projectId, monthStart])
  @@index([tenantId, applicationId, monthStart])
  @@map("budget_ledger_entries")
}

model BudgetQuota {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  budgetScopeType         String   @map("budget_scope_type")
  budgetScopeId           String   @map("budget_scope_id")
  monthStart              DateTime @map("month_start") @db.Date
  limitMicroUsd           BigInt   @map("limit_micro_usd")
  warningThresholdPercent Int      @default(80) @map("warning_threshold_percent")
  status                  String   @default("active")
  source                  String   @default("manual")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, budgetScopeType, budgetScopeId, monthStart])
  @@index([tenantId, monthStart, status])
  @@map("budget_quotas")
}

model BudgetAuditLog {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  projectId             String?  @map("project_id") @db.Uuid
  applicationId         String?  @map("application_id") @db.Uuid
  budgetScopeType       String   @map("budget_scope_type")
  budgetScopeId         String   @map("budget_scope_id")
  action                String   @default("budget_updated")
  actorType             String   @default("admin_placeholder") @map("actor_type")
  actorId               String?  @map("actor_id") @db.Uuid
  oldLimitMicroUsd      BigInt?  @map("old_limit_micro_usd")
  newLimitMicroUsd      BigInt?  @map("new_limit_micro_usd")
  oldBudgetLimitMode    String?  @map("old_budget_limit_mode")
  newBudgetLimitMode    String?  @map("new_budget_limit_mode")
  oldBudgetLimitPercent Decimal? @map("old_budget_limit_percent") @db.Decimal(5, 2)
  newBudgetLimitPercent Decimal? @map("new_budget_limit_percent") @db.Decimal(5, 2)
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, budgetScopeType, budgetScopeId, createdAt])
  @@index([projectId, createdAt])
  @@index([applicationId, createdAt])
  @@map("budget_audit_logs")
}

model NotificationEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  projectId          String?  @map("project_id") @db.Uuid
  applicationId      String?  @map("application_id") @db.Uuid
  budgetScopeType    String   @map("budget_scope_type")
  budgetScopeId      String   @map("budget_scope_id")
  eventType          String   @map("event_type")
  severity           String
  status             String   @default("pending")
  recipientScopeType String   @map("recipient_scope_type")
  recipientScopeId   String   @map("recipient_scope_id")
  recipientRole      String   @map("recipient_role")
  eventKey           String   @unique @map("event_key")
  limitMicroUsd      BigInt?  @map("limit_micro_usd")
  usedMicroUsd       BigInt?  @map("used_micro_usd")
  remainingMicroUsd  BigInt?  @map("remaining_micro_usd")
  usagePercent       Decimal? @map("usage_percent") @db.Decimal(12, 4)
  sourceRequestId    String?  @map("source_request_id")
  monthStart         DateTime @map("month_start") @db.Date
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([tenantId, severity, createdAt])
  @@index([tenantId, budgetScopeType, budgetScopeId, monthStart])
  @@index([projectId, createdAt])
  @@index([applicationId, createdAt])
  @@map("notification_events")
}

model RuntimeConfig {
  id            String                    @id @default(uuid()) @db.Uuid
  tenantId      String                    @db.Uuid
  projectId     String                    @db.Uuid
  applicationId String                    @db.Uuid
  configVersion String
  configHash    String
