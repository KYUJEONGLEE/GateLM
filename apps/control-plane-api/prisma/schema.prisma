generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DISABLED
}

enum RuntimeConfigPublishState {
  DRAFT
  ACTIVE
  SUPERSEDED
  ROLLED_BACK
}

enum ProviderConnectionStatus {
  ACTIVE
  DISABLED
  DEGRADED
}

model Tenant {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  status    ResourceStatus @default(ACTIVE)
  totalBudgetUsd Decimal? @default(1000) @db.Decimal(12, 2)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  projects            Project[]
  applications        Application[]
  providerConnections ProviderConnection[]
  applicationProviderConnections ApplicationProviderConnection[]
  apiKeys             GatewayApiKey[]
  appTokens           AppToken[]
  runtimeConfigs      RuntimeConfig[]
  runtimeSnapshots    RuntimeSnapshot[]
  activeSnapshots     ActiveRuntimeSnapshot[]
  teams               Team[]
  projectTeamAssignments ProjectTeamAssignment[]
  tenantMemberships   TenantMembership[]
  conversations        Conversation[]
  chatMessages         ChatMessage[]

  @@map("tenants")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String
  name            String?
  passwordHash    String?
  authProvider    String    @default("local")
  status          String    @default("pending_email_verification")
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  emailVerificationCodes EmailVerificationCode[]
  authSessions           AuthSession[]
  oauthAccounts          OAuthAccount[]
  tenantMemberships      TenantMembership[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model EmailVerificationCode {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  codeHash           String
  failedAttemptCount Int       @default(0)
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  sessionTokenHash String
  kind             String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionTokenHash])
  @@index([userId, kind, revokedAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model OAuthAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  provider        String
  providerSubject String
  email           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([email])
  @@map("oauth_accounts")
}

model TenantMembership {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  role      String
  status    String    @default("active")
  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, role, status])
  @@map("tenant_memberships")
}

model Project {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  totalBudgetUsd Decimal? @default(100) @db.Decimal(12, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  applications        Application[]
  providerConnections ProviderConnection[]
  applicationProviderConnections ApplicationProviderConnection[]
  apiKeys             GatewayApiKey[]
  appTokens           AppToken[]
  runtimeConfigs      RuntimeConfig[]
  runtimeSnapshots    RuntimeSnapshot[]
  activeSnapshots     ActiveRuntimeSnapshot[]
  projectTeamAssignments ProjectTeamAssignment[]
  conversations        Conversation[]
  chatMessages         ChatMessage[]

  @@index([tenantId])
  @@map("projects")
}

model Team {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  projectTeamAssignments ProjectTeamAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("teams")
}

model ProjectTeamAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  projectId  String   @db.Uuid
  teamId     String   @db.Uuid
  createdAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  team    Team    @relation(fields: [teamId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([teamId])
  @@unique([projectId, teamId])
  @@map("project_team_assignments")
}

model Application {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  projectId   String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  budgetLimitUsd Decimal? @db.Decimal(12, 2)
  budgetLimitMode String @default("FIXED")
  budgetLimitPercent Decimal? @db.Decimal(5, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  project        Project         @relation(fields: [projectId], references: [id])
  appTokens      AppToken[]
  providerConnections ApplicationProviderConnection[]
  runtimeConfigs RuntimeConfig[]
  runtimeSnapshots RuntimeSnapshot[]
  activeSnapshots  ActiveRuntimeSnapshot[]
  conversations    Conversation[]
  chatMessages     ChatMessage[]

  @@index([tenantId])
  @@index([projectId])
  @@map("applications")
}

model ProviderConnection {
  id                String                   @id @default(uuid()) @db.Uuid
  tenantId          String                   @db.Uuid
  projectId         String?                  @db.Uuid
  provider          String
  displayName       String
  status            ProviderConnectionStatus @default(ACTIVE)
  baseUrl           String
  timeoutMs         Int                      @default(30000)
  secretRef         String?
  credentialPrefix  String?
  credentialLast4   String?
  resolver          String                   @default("none")
  providerConfig    Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  applicationProviderConnections ApplicationProviderConnection[]

  @@index([tenantId])
  @@unique([projectId, provider])
  @@map("provider_connections")
}

model ApplicationProviderConnection {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  projectId            String   @db.Uuid
  applicationId        String   @db.Uuid
  providerConnectionId String   @db.Uuid
  createdAt            DateTime @default(now())

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  project            Project            @relation(fields: [projectId], references: [id])
  application        Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  providerConnection ProviderConnection @relation(fields: [providerConnectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([providerConnectionId])
  @@unique([applicationId, providerConnectionId])
  @@map("application_provider_connections")
}

model ProviderPreset {
  providerKey        String         @id
  displayName        String
  adapterType        String
  baseUrl            String
  modelsEndpointPath String         @default("/models")
  credentialRequired Boolean        @default(true)
  defaultResolver    String         @default("environment")
  defaultTimeoutMs   Int            @default(30000)
  status             ResourceStatus @default(ACTIVE)
  sortOrder          Int            @default(100)
  providerConfig     Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status, sortOrder])
  @@map("provider_presets")
}

model GatewayApiKey {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([prefix])
  @@map("gateway_api_keys")
}

model AppToken {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  applicationId String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  project     Project     @relation(fields: [projectId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([prefix])
  @@map("app_tokens")
}

model RuntimeConfig {
  id            String                    @id @default(uuid()) @db.Uuid
  tenantId      String                    @db.Uuid
  projectId     String                    @db.Uuid
  applicationId String                    @db.Uuid
  configVersion String
  configHash    String
  publishState  RuntimeConfigPublishState @default(DRAFT)
  document      Json
  effectiveAt   DateTime?
  publishedAt   DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  project          Project           @relation(fields: [projectId], references: [id])
  application      Application       @relation(fields: [applicationId], references: [id])
  runtimeSnapshots RuntimeSnapshot[]

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([publishState])
  @@unique([applicationId, configVersion])
  @@map("runtime_configs")
}

model RuntimeSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  projectId       String   @db.Uuid
  applicationId   String   @db.Uuid
  runtimeConfigId String?  @db.Uuid
  version         BigInt
  contentHash     String
  snapshotBody    Json
  publishedAt     DateTime
  publishedBy     String
  createdAt       DateTime @default(now())

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  project        Project                 @relation(fields: [projectId], references: [id])
  application    Application             @relation(fields: [applicationId], references: [id])
  runtimeConfig  RuntimeConfig?          @relation(fields: [runtimeConfigId], references: [id], onDelete: SetNull)
  activePointers ActiveRuntimeSnapshot[]

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([tenantId, projectId, applicationId, version])
  @@unique([applicationId, version])
  @@map("runtime_snapshots")
}

model ActiveRuntimeSnapshot {
  tenantId          String   @db.Uuid
  projectId         String   @db.Uuid
  applicationId     String   @db.Uuid
  runtimeSnapshotId String   @db.Uuid
  updatedAt         DateTime @updatedAt
  updatedBy         String

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  project         Project         @relation(fields: [projectId], references: [id])
  application     Application     @relation(fields: [applicationId], references: [id])
  runtimeSnapshot RuntimeSnapshot @relation(fields: [runtimeSnapshotId], references: [id])

  @@id([tenantId, projectId, applicationId])
  @@index([runtimeSnapshotId])
  @@map("active_runtime_snapshots")
}

model Conversation {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @db.Uuid
  projectId               String    @db.Uuid
  applicationId           String    @db.Uuid
  endUserId               String?
  title                   String?
  status                  String    @default("active")
  contextRetentionEnabled Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  project     Project       @relation(fields: [projectId], references: [id])
  application Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([tenantId, projectId, applicationId, deletedAt])
  @@index([applicationId, updatedAt])
  @@index([endUserId])
  @@map("conversations")
}

model ChatMessage {
  id              String   @id @default(uuid()) @db.Uuid
  conversationId  String   @db.Uuid
  tenantId        String   @db.Uuid
  projectId       String   @db.Uuid
  applicationId   String   @db.Uuid
  role            String
  safeContent     String?
  contentPolicy   String   @default("retained")
  requestId       String?
  parentMessageId String?  @db.Uuid
  sequence        Int
  createdAt       DateTime @default(now())

  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  project       Project       @relation(fields: [projectId], references: [id])
  application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parentMessage ChatMessage?  @relation("ChatMessageParent", fields: [parentMessageId], references: [id], onDelete: SetNull)
  childMessages ChatMessage[] @relation("ChatMessageParent")

  @@unique([conversationId, sequence])
  @@index([tenantId, projectId, applicationId])
  @@index([conversationId, sequence])
  @@index([requestId])
  @@index([parentMessageId])
  @@map("chat_messages")
}
