  @@index([tenantId, surface, projectId, dimensionType, grain, bucketStart], map: "dashboard_rollup_dimensions_project_idx")
  @@index([tenantId, surface, applicationId, dimensionType, grain, bucketStart], map: "dashboard_rollup_dimensions_application_idx")
  @@map("dashboard_rollup_dimensions")
}

model Conversation {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @db.Uuid
  projectId               String    @db.Uuid
  applicationId           String    @db.Uuid
  endUserId               String?
  title                   String?
  status                  String    @default("active")
  contextRetentionEnabled Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  project     Project       @relation(fields: [projectId], references: [id])
  application Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([tenantId, projectId, applicationId, deletedAt])
  @@index([applicationId, updatedAt])
  @@index([endUserId])
  @@map("conversations")
}

model ChatMessage {
  id              String   @id @default(uuid()) @db.Uuid
  conversationId  String   @db.Uuid
  tenantId        String   @db.Uuid
  projectId       String   @db.Uuid
  applicationId   String   @db.Uuid
  role            String
  safeContent     String?
  contentPolicy   String   @default("retained")
  requestId       String?
  parentMessageId String?  @db.Uuid
  sequence        Int
  createdAt       DateTime @default(now())

  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  project       Project       @relation(fields: [projectId], references: [id])
  application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parentMessage ChatMessage?  @relation("ChatMessageParent", fields: [parentMessageId], references: [id], onDelete: SetNull)
  childMessages ChatMessage[] @relation("ChatMessageParent")

  @@unique([conversationId, sequence])
  @@index([tenantId, projectId, applicationId])
  @@index([conversationId, sequence])
  @@index([requestId])
  @@index([parentMessageId])
  @@map("chat_messages")
}
