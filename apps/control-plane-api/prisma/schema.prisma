generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DISABLED
}

enum RuntimeConfigPublishState {
  DRAFT
  ACTIVE
  SUPERSEDED
  ROLLED_BACK
}

enum ProviderConnectionStatus {
  ACTIVE
  DISABLED
  DEGRADED
}

model Tenant {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  status    ResourceStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  projects            Project[]
  applications        Application[]
  providerConnections ProviderConnection[]
  apiKeys             GatewayApiKey[]
  appTokens           AppToken[]
  runtimeConfigs      RuntimeConfig[]
  runtimeSnapshots    RuntimeSnapshot[]
  activeSnapshots     ActiveRuntimeSnapshot[]

  @@map("tenants")
}

model Project {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  applications        Application[]
  providerConnections ProviderConnection[]
  apiKeys             GatewayApiKey[]
  appTokens           AppToken[]
  runtimeConfigs      RuntimeConfig[]
  runtimeSnapshots    RuntimeSnapshot[]
  activeSnapshots     ActiveRuntimeSnapshot[]

  @@index([tenantId])
  @@map("projects")
}

model Application {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  projectId   String         @db.Uuid
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  project        Project         @relation(fields: [projectId], references: [id])
  appTokens      AppToken[]
  runtimeConfigs RuntimeConfig[]
  runtimeSnapshots RuntimeSnapshot[]
  activeSnapshots  ActiveRuntimeSnapshot[]

  @@index([tenantId])
  @@index([projectId])
  @@map("applications")
}

model ProviderConnection {
  id                String                   @id @default(uuid()) @db.Uuid
  tenantId          String                   @db.Uuid
  projectId         String                   @db.Uuid
  provider          String
  displayName       String
  status            ProviderConnectionStatus @default(ACTIVE)
  baseUrl           String
  timeoutMs         Int                      @default(30000)
  secretRef         String?
  credentialPrefix  String?
  credentialLast4   String?
  resolver          String                   @default("none")
  providerConfig    Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@unique([projectId, provider])
  @@map("provider_connections")
}

model GatewayApiKey {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([prefix])
  @@map("gateway_api_keys")
}

model AppToken {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  projectId     String           @db.Uuid
  applicationId String           @db.Uuid
  displayName   String
  prefix        String
  last4         String
  secretHash    String
  hashAlgorithm String           @default("sha256")
  status        CredentialStatus @default(ACTIVE)
  scopes        String[]
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  project     Project     @relation(fields: [projectId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([prefix])
  @@map("app_tokens")
}

model RuntimeConfig {
  id            String                    @id @default(uuid()) @db.Uuid
  tenantId      String                    @db.Uuid
  projectId     String                    @db.Uuid
  applicationId String                    @db.Uuid
  configVersion String
  configHash    String
  publishState  RuntimeConfigPublishState @default(DRAFT)
  document      Json
  effectiveAt   DateTime?
  publishedAt   DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  project          Project           @relation(fields: [projectId], references: [id])
  application      Application       @relation(fields: [applicationId], references: [id])
  runtimeSnapshots RuntimeSnapshot[]

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([publishState])
  @@unique([applicationId, configVersion])
  @@map("runtime_configs")
}

model RuntimeSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  projectId       String   @db.Uuid
  applicationId   String   @db.Uuid
  runtimeConfigId String?  @db.Uuid
  version         BigInt
  contentHash     String
  snapshotBody    Json
  publishedAt     DateTime
  publishedBy     String
  createdAt       DateTime @default(now())

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  project        Project                 @relation(fields: [projectId], references: [id])
  application    Application             @relation(fields: [applicationId], references: [id])
  runtimeConfig  RuntimeConfig?          @relation(fields: [runtimeConfigId], references: [id], onDelete: SetNull)
  activePointers ActiveRuntimeSnapshot[]

  @@index([tenantId])
  @@index([projectId])
  @@index([applicationId])
  @@index([tenantId, projectId, applicationId, version])
  @@unique([applicationId, version])
  @@map("runtime_snapshots")
}

model ActiveRuntimeSnapshot {
  tenantId          String   @db.Uuid
  projectId         String   @db.Uuid
  applicationId     String   @db.Uuid
  runtimeSnapshotId String   @db.Uuid
  updatedAt         DateTime @updatedAt
  updatedBy         String

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  project         Project         @relation(fields: [projectId], references: [id])
  application     Application     @relation(fields: [applicationId], references: [id])
  runtimeSnapshot RuntimeSnapshot @relation(fields: [runtimeSnapshotId], references: [id])

  @@id([tenantId, projectId, applicationId])
  @@index([runtimeSnapshotId])
  @@map("active_runtime_snapshots")
}
