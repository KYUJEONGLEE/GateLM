{
  "name": "gatelm",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "verify:v2-docs": "node scripts/verify-v2-docs.mjs",
    "verify:v2-final": "node scripts/verify-v2-final.mjs",
    "v2:p0:bootstrap:describe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-p0-bootstrap-check.ps1 -DescribeOnly",
    "v2:p0:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-p0-bootstrap-check.ps1",
    "v2:p0:bootstrap:apps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-p0-bootstrap-check.ps1 -CheckApps -RequireActiveSnapshot",
    "v2:provider:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-provider-e2e-main-path.ps1",
    "v2:request-log:consistency": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-request-log-outcome-consistency.ps1",
    "v2:k6:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-k6-smoke.ps1",
    "v2:final:hardening": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-final-hardening.ps1",
    "v2:rc:freeze": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/v2-rc-freeze.ps1",
    "dev:control-plane": "pnpm --filter @gatelm/control-plane-api dev",
    "build:control-plane": "pnpm --filter @gatelm/control-plane-api build",
    "typecheck:control-plane": "pnpm --filter @gatelm/control-plane-api typecheck",
    "test:control-plane": "pnpm --filter @gatelm/control-plane-api test",
    "dev:web": "pnpm --filter @gatelm/web dev",
    "build:web": "pnpm --filter @gatelm/web build",
    "lint:web": "pnpm --filter @gatelm/web lint",
    "typecheck:web": "pnpm --filter @gatelm/web typecheck"
  }
}
