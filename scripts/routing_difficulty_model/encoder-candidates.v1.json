      "operatorScope": ["MatMul"],
      "weightType": "QInt8",
      "activationType": "dynamic_runtime",
      "perChannel": false,
      "reduceRange": false,
      "maximumAccuracyDrop": 0.005,
      "maximumMinimumLanguageAccuracyDrop": 0.01,
      "maximumComplexToSimpleCountIncrease": 0,
      "minimumP95LatencyImprovementRatio": 0.05,
      "minimumSteadyRssReductionRatio": 0.1,
      "minimumArtifactSizeReductionRatio": 0.5
    },
    "qualityProbe": {
      "version": "difficulty-semantic-logistic-probe.v1",
      "fitSplit": "train",
      "selectionSplit": "calibration",
      "holdoutUse": "once_after_selection",
      "solver": "liblinear",
      "penalty": "l2",
      "c": 1.0,
      "maxIterations": 1000,
      "classWeight": "none"
    },
    "candidateSelectionPriority": [
      "lowest_calibration_complex_to_simple_count",
      "highest_calibration_accuracy",
      "highest_minimum_language_accuracy",
      "lowest_cpu_p95_latency",
      "lowest_peak_rss",
      "smallest_artifact_size",
      "candidate_id_ascending"
    ]
  },
