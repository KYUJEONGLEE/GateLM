# Canonical local development environment for the repository.
# Do not create apps/control-plane-api/.env; Control Plane local settings belong here.

COMPOSE_PROJECT_NAME=gatelm

NODE_VERSION=22
PNPM_VERSION=9.15.0
GO_VERSION=1.24
PYTHON_VERSION=3.12

POSTGRES_USER=gatelm
POSTGRES_PASSWORD=gatelm
POSTGRES_DB=gatelm
POSTGRES_PORT=5432

REDIS_PORT=6379
CONTROL_PLANE_PORT=3001
CHAT_WEB_PORT=3002
CHAT_API_PORT=3003
GATEWAY_PORT=8080
MOCK_PROVIDER_PORT=8090
MOCK_PROVIDER_DEFAULT_LATENCY_MS=150
MOCK_PROVIDER_ERROR_MODE=off

# Observability stack
PROMETHEUS_PORT=9090
PROMETHEUS_GATEWAY_METRICS_TARGET=host.docker.internal:8080
PROMETHEUS_SCRAPE_INTERVAL=5s
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=24h
GRAFANA_PORT=3005
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GATELM_OBSERVABILITY_EVIDENCE_REPORT_DIR=reports/observability-stack-evidence
DATABASE_URL=postgresql://gatelm:gatelm@localhost:5432/gatelm?schema=public
REDIS_URL=redis://localhost:6379
CONTROL_PLANE_ADMIN_AUTH_MODE=session_cookie
CONTROL_PLANE_WEB_ORIGIN=http://localhost:3000
CONTROL_PLANE_AUTH_STATE_SECRET=replace-me-with-random-value
TENANT_CHAT_PROJECTOR_ENABLED=false
TENANT_CHAT_PROJECTOR_INTERVAL_MS=1000
TENANT_CHAT_PROJECTOR_BATCH_SIZE=50
TENANT_CHAT_PROJECTOR_MAX_ATTEMPTS=5
DASHBOARD_ROLLUP_ENABLED=false
DASHBOARD_ROLLUP_INTERVAL_MS=1000
DASHBOARD_ROLLUP_DISCOVERY_BATCH_SIZE=500
DASHBOARD_ROLLUP_BUCKET_BATCH_SIZE=8
DASHBOARD_ROLLUP_DISCOVERY_LAG_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_INTERVAL_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_LOOKBACK_MS=900000
GATELM_APPLICATION_BASE_URL=http://localhost:3002
NEXT_PUBLIC_GATELM_APPLICATION_BASE_URL=http://localhost:3002
GATELM_CHAT_WEB_ORIGIN=http://chat.localhost:3002
TENANT_CHAT_API_BASE_URL=http://localhost:3003
TENANT_CHAT_WEB_SERVICE_TOKEN=replace-me-with-random-chat-web-service-token
TENANT_CHAT_CONTROL_PLANE_SERVICE_TOKEN=replace-me-with-random-chat-control-plane-token
TENANT_CHAT_ACCESS_JWT_SECRET=replace-me-with-random-chat-access-secret
TENANT_CHAT_INTENT_SECRET=replace-me-with-random-chat-intent-secret
TENANT_CHAT_GOOGLE_REDIRECT_URI=http://chat.localhost:3002/auth/google/callback

# Auth onboarding
# Leave AUTH_EMAIL_TRANSPORT=dev_memory for local fake email verification.
# Set AUTH_EMAIL_TRANSPORT=smtp and fill SMTP_* to send real verification emails.
AUTH_EMAIL_TRANSPORT=dev_memory
CONTROL_PLANE_AUTH_DEV_AUTO_VERIFY=true
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TLS_MODE=opportunistic
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Provider demo mode
GATELM_DEMO_PROVIDER_MODE=mock

# Provider credentials
OPENAI_API_KEY=
GEMINI_API_KEY=

# Dashboard AI Insights
# Runs in mock mode until a server-side key is configured. Set AI_INSIGHTS_ENABLED=false to force mock.
# Do not use NEXT_PUBLIC_ for provider keys.
AI_INSIGHTS_ENABLED=true
AI_INSIGHTS_PROVIDER=openai
AI_INSIGHTS_BASE_URL=https://api.openai.com/v1
AI_INSIGHTS_MODEL=gpt-5.5
AI_INSIGHTS_API_KEY=
AI_INSIGHTS_TIMEOUT_MS=8000

# OpenAI
GATELM_DEMO_OPENAI_BASE_URL=https://api.openai.com/v1
GATELM_DEMO_OPENAI_LOW_COST_MODEL=gpt-4o-mini
GATELM_DEMO_OPENAI_BALANCED_MODEL=gpt-4o
GATELM_DEMO_OPENAI_EXTRA_MODELS=gpt-5.4-mini,gpt-5.4
GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1
GATEWAY_OPENAI_LOW_COST_MODEL_NAME=gpt-4o-mini
GATEWAY_OPENAI_BALANCED_MODEL_NAME=gpt-4o
GATEWAY_OPENAI_EXTRA_MODELS=gpt-5.4-mini,gpt-5.4

# Control Plane / Gateway
GATEWAY_CONTROL_PLANE_BASE_URL=http://localhost:3001
CONTROL_PLANE_INTERNAL_SERVICE_TOKEN=local-control-plane-internal-token-for-dev-only
GATEWAY_CONTROL_PLANE_INTERNAL_TOKEN=local-control-plane-internal-token-for-dev-only
# Optional in local development. Set the same non-placeholder value for Web and Gateway to exercise auth.
GATEWAY_OBSERVABILITY_INTERNAL_TOKEN=
GATEWAY_OBSERVABILITY_AUTH_REQUIRED=false
GATEWAY_RUNTIME_SNAPSHOT_CACHE_ENABLED=true
GATEWAY_RUNTIME_SNAPSHOT_CACHE_TTL_MS=5000
GATEWAY_RUNTIME_SNAPSHOT_CACHE_STALE_TTL_MS=60000
GATEWAY_PROVIDER_CATALOG_CACHE_ENABLED=true
GATEWAY_PROVIDER_CATALOG_CACHE_TTL_MS=5000
GATEWAY_PROVIDER_CATALOG_CACHE_STALE_TTL_MS=60000
CONTROL_PLANE_PROVIDER_CREDENTIAL_ENV_MAP=credential_ref_openai_main=OPENAI_API_KEY,credential_ref_gemini_main=GEMINI_API_KEY,provider_credential:00000000-0000-4000-8000-000000000601=OPENAI_API_KEY
GATEWAY_PROVIDER_CREDENTIAL_ENV_MAP=credential_ref_openai_main=OPENAI_API_KEY,credential_ref_gemini_main=GEMINI_API_KEY,provider_credential:00000000-0000-4000-8000-000000000601=OPENAI_API_KEY
# Required when provider keys are entered in the Console. Use a 32-byte raw key, or base64:/hex: encoded 32-byte key.
GATELM_PROVIDER_CREDENTIAL_ENCRYPTION_KEY=
GATELM_PROVIDER_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1
GATEWAY_DEFAULT_PROVIDER=mock
GATEWAY_DEFAULT_MODEL=mock-balanced
GATEWAY_LOW_COST_MODEL=mock-fast
GATEWAY_HIGH_QUALITY_MODEL=mock-smart
GATEWAY_ROUTING_POLICY_HASH=route_p0_v1
GATEWAY_SHORT_PROMPT_MAX_CHARS=300
GATEWAY_READINESS_TIMEOUT_MS=1000
GATEWAY_PROVIDER_TIMEOUT_MS=5000
GATEWAY_MAX_REQUEST_BODY_BYTES=4194304
MOCK_PROVIDER_BASE_URL=http://localhost:8090

# Rate limit
# token_bucket interprets 60 reqs / 60 sec as capacity 60 and refill 1 token/sec.
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_BACKEND=redis
GATEWAY_RATE_LIMIT_ALGORITHM=token_bucket
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_RATE_LIMIT_LIMIT=60
GATEWAY_RATE_LIMIT_REDIS_KEY_PREFIX=

# Demo identity
GATELM_DEMO_API_KEY=glm_api_test_redacted
GATELM_DEMO_APP_TOKEN=glm_app_token_test_redacted
GATELM_DEMO_TENANT_ID=00000000-0000-4000-8000-000000000100
GATELM_DEMO_PROJECT_ID=00000000-0000-4000-8000-000000000200
GATELM_DEMO_APPLICATION_ID=00000000-0000-4000-8000-000000000300
GATELM_DEMO_API_KEY_ID=00000000-0000-4000-8000-000000000400
GATELM_DEMO_APP_TOKEN_ID=00000000-0000-4000-8000-000000000500

# Async logging
GATEWAY_ASYNC_LOG_ENABLED=true
GATEWAY_ASYNC_LOG_QUEUE_SIZE=1024
GATEWAY_ASYNC_LOG_WORKER_COUNT=2
GATEWAY_ASYNC_LOG_WRITE_TIMEOUT_MS=2000
GATEWAY_ASYNC_LOG_SHUTDOWN_TIMEOUT_MS=5000

# Semantic Cache
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_MODE=shadow
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_THRESHOLD_GENERAL=0.92
SEMANTIC_CACHE_TOP_K=3
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_STORE=in_memory
SEMANTIC_CACHE_MAX_ENTRIES=1000
SEMANTIC_CACHE_POLICY_VERSION=v1
SEMANTIC_CACHE_KEY_VERSION=v1
SEMANTIC_CACHE_INTENT_POLICY_PATH=

# Semantic Cache Embedding
SEMANTIC_CACHE_EMBEDDING_PROVIDER=fake
SEMANTIC_CACHE_EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_EMBEDDING_DIMENSIONS=
SEMANTIC_CACHE_EMBEDDING_TIMEOUT_MS=3000
SEMANTIC_CACHE_OPENAI_BASE_URL=https://api.openai.com/v1

# Semantic Cache Category Policy
SEMANTIC_CACHE_ALLOW_CATEGORIES=general
SEMANTIC_CACHE_DENY_CATEGORIES=account_access,support_refund,code,translation,summarization,extraction_json,reasoning,sensitive,tool_call,unknown

# Semantic Cache Cacheability Classifier
SEMANTIC_CACHE_CLASSIFIER_ENABLED=false
SEMANTIC_CACHE_CLASSIFIER_TYPE=stub
SEMANTIC_CACHE_CLASSIFIER_ENDPOINT=
SEMANTIC_CACHE_CLASSIFIER_MIN_CONFIDENCE=0.90
SEMANTIC_CACHE_CLASSIFIER_TIMEOUT_MS=30

# Semantic Cache shadow mode with real OpenAI embeddings
# SEMANTIC_CACHE_ENABLED=true
# SEMANTIC_CACHE_MODE=shadow
# SEMANTIC_CACHE_INTENT_POLICY_PATH=apps/gateway-core/config/semantic-cache/semantic_cache_policy_ko_v1.json
# SEMANTIC_CACHE_EMBEDDING_PROVIDER=openai
# SEMANTIC_CACHE_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_openai_api_key

# AI Safety Sidecar
# Gateway calls this local sidecar before routing/cache/provider when enabled.
GATEWAY_AI_SAFETY_SIDECAR_ENABLED=true
GATEWAY_AI_SAFETY_SIDECAR_URL=http://127.0.0.1:8001/internal/ai-safety/v1/detect
GATEWAY_AI_SAFETY_SIDECAR_TIMEOUT_MS=750
GATEWAY_AI_SAFETY_SIDECAR_MODEL_ID=openai/privacy-filter
GATEWAY_AI_SAFETY_SIDECAR_DETECTOR_SET=privacy-filter-default
GATEWAY_AI_SAFETY_SIDECAR_LOCALE=ko-KR
GATEWAY_AI_SAFETY_SIDECAR_MODE=enforce

# AI Service local detector models. Keep these local/offline; do not send
# prompts to hosted model inference APIs for request-side safety.
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_TRANSFORMERS_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1
AI_SERVICE_AI_SAFETY_DETECTOR_RUNTIME=onnx
AI_SERVICE_AI_SAFETY_MICRO_BATCH_SIZE=4
AI_SERVICE_AI_SAFETY_ML_ALLOWED_DETECTOR_TYPES=phone_number,secret
AI_SERVICE_AI_SAFETY_DETECTOR_MODEL_ID=.cache/onnx/releases/tenant-chat-pii-models-20260715/openai--privacy-filter
# Optional comma-separated local paths. Leave blank for the OpenAI-only runtime.
AI_SERVICE_AI_SAFETY_ADDITIONAL_DETECTOR_MODEL_IDS=
