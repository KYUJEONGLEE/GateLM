# GateLM four-host distributed performance topology.
# Do not use this file directly. Generate a secret-bearing file with
# scripts/perf-distributed-init.sh and keep it mode 600.

GATELM_PERF_TOPOLOGY=distributed
GATELM_PERF_TOPOLOGY_ID=000000000000000000000000
GATELM_PERF_GIT_SHA=0000000000000000000000000000000000000000
GATELM_PERF_LOADGEN_PRIVATE_IP=10.77.1.10
GATELM_PERF_GATEWAY_PRIVATE_IP=10.77.1.20
GATELM_PERF_DATA_PRIVATE_IP=10.77.1.30
GATELM_PERF_MOCK_PRIVATE_IP=10.77.1.40
GATELM_PERF_GATEWAY_PORT=18080
GATELM_PERF_CONTROL_PLANE_PORT=3001
GATELM_PERF_POSTGRES_PORT=5432
GATELM_PERF_REDIS_PORT=6379
GATELM_PERF_MOCK_PORT=8090

POSTGRES_USER=gatelm_perf
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=gatelm_perf
REDIS_PASSWORD=replace-me
CONTROL_PLANE_AUTH_STATE_SECRET=replace-me
CONTROL_PLANE_INTERNAL_SERVICE_TOKEN=replace-me
GATEWAY_CONTROL_PLANE_INTERNAL_TOKEN=replace-me
TENANT_CHAT_CONTROL_PLANE_SERVICE_TOKEN=replace-me
GATEWAY_EXACT_CACHE_KEY_SECRET=replace-me

GATELM_DEMO_API_KEY=replace-me
GATELM_DEMO_APP_TOKEN=replace-me
GATELM_DEMO_TENANT_ID=00000000-0000-4000-8000-000000000100
GATELM_DEMO_PROJECT_ID=00000000-0000-4000-8000-000000000200
GATELM_DEMO_APPLICATION_ID=00000000-0000-4000-8000-000000000300
GATELM_DEMO_API_KEY_ID=00000000-0000-4000-8000-000000000400
GATELM_DEMO_APP_TOKEN_ID=00000000-0000-4000-8000-000000000500

GATELM_PERF_RUNTIME_RATE_LIMIT_LIMIT=100000
MOCK_PROVIDER_DEFAULT_LATENCY_MS=100
DASHBOARD_ROLLUP_ENABLED=false
DASHBOARD_ROLLUP_BUILD_MODE=legacy
DASHBOARD_ROLLUP_INTERVAL_MS=1000
DASHBOARD_ROLLUP_PROJECT_APPLICATION_ENABLED=true
DASHBOARD_ROLLUP_DISCOVERY_BATCH_SIZE=500
DASHBOARD_ROLLUP_BUCKET_BATCH_SIZE=8
DASHBOARD_ROLLUP_DISCOVERY_LAG_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_INTERVAL_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_LOOKBACK_MS=900000
GATEWAY_ANALYTICS_POLICY_IMPACT_READ_MODE=raw
GATEWAY_ANALYTICS_POLICY_IMPACT_MAX_RAW_TAIL_MS=120000
GATELM_PERF_PROVIDER_MAX_IDLE_CONNS=1024
GATELM_PERF_PROVIDER_MAX_IDLE_CONNS_PER_HOST=512
GATELM_PERF_PROVIDER_MAX_CONNS_PER_HOST=512
GATELM_PERF_DATABASE_MAX_CONNS=32
GATELM_PERF_DATABASE_MIN_CONNS=4
GATELM_PERF_LOG_DATABASE_MAX_CONNS=8
GATELM_PERF_LOG_DATABASE_MIN_CONNS=2
GATELM_PERF_ASYNC_LOG_QUEUE_SIZE=20000
GATELM_PERF_ASYNC_LOG_WORKER_COUNT=4
GATELM_PERF_ASYNC_LOG_BATCH_SIZE=100

# Live Provider values must remain empty.
GATELM_PROVIDER_CREDENTIAL_ENCRYPTION_KEY=
