# GateLM dedicated load-generator settings.
# Copy to .env.loadgen on the load-generator host and run: chmod 600 .env.loadgen

# Use the target host's private Gateway endpoint. HTTP is accepted only for an
# RFC1918 IPv4 address; a DNS hostname requires HTTPS.
GATELM_LOADGEN_GATEWAY_BASE_URL=http://10.0.0.10:18080

# Copy only the isolated performance API Key and App Token from the target.
GATELM_DEMO_API_KEY=replace-me-perf-gateway-api-key
GATELM_DEMO_APP_TOKEN=replace-me-perf-app-token
