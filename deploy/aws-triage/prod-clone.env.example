# Non-secret overlay for the four-host production clone.
# Keep the exact protected production .env separately as .env.prod-clone.base.
# Copy this file to .env.prod-clone and chmod both files to 600.

# The source checkout used for Docker builds must be clean and exactly this SHA.
GATELM_PROD_CLONE_SOURCE_SHA=13d2964fe76e074e4e61f03ece588794fe0cc5e4
GATELM_PROD_CLONE_DB_SOURCE_SHA=13d2964fe76e074e4e61f03ece588794fe0cc5e4
GATELM_PROD_CLONE_IMAGE_TAG=13d2964f
GATELM_PROD_CLONE_BUILD_CONTEXT=/home/ubuntu/GateLM-prod-clone-source-13d2964f
GATELM_PROD_CLONE_E5_BUNDLE_CONTEXT=/home/ubuntu/GateLM-prod-clone-source-13d2964f/.tmp/gateway-e5-runtime-bundle

GATELM_PROD_CLONE_EDGE_PRIVATE_IP=10.77.1.10
GATELM_PROD_CLONE_GATEWAY_PRIVATE_IP=10.77.1.20
GATELM_PROD_CLONE_DATA_PRIVATE_IP=10.77.1.30
GATELM_PROD_CLONE_AI_PRIVATE_IP=10.77.1.40
GATELM_PROD_CLONE_SECRET_ROOT=/home/ubuntu/gatelm-prod-clone-secrets
GATELM_PROD_CLONE_POSTGRES_VOLUME_NAME=gatelm-prod-clone-13d2964f-postgres-data
GATELM_PROD_CLONE_REDIS_VOLUME_NAME=gatelm-prod-clone-13d2964f-redis-data
GATELM_PROD_CLONE_CADDY_DATA_VOLUME_NAME=gatelm-prod-clone-13d2964f-caddy-data
GATELM_PROD_CLONE_CADDY_CONFIG_VOLUME_NAME=gatelm-prod-clone-13d2964f-caddy-config

# benchmark and rehearsal are private, Mock-only, and SMTP-disabled.
# production is permitted only after final dump/restore and explicit cutover approval.
GATELM_PROD_CLONE_PHASE=benchmark
GATELM_PROD_CLONE_ALLOW_LIVE_PROVIDER=false
GATELM_PROD_CLONE_ALLOW_SMTP=false
GATELM_PROD_CLONE_AUTH_CACHE_CONFIG=false
GATELM_PROD_CLONE_CADDYFILE=./Caddyfile.prod-clone.rehearsal

GATELM_PUBLIC_DOMAIN=gatelm.co.kr
GATELM_PUBLIC_BASE_URL=https://gatelm.co.kr
GATELM_CHAT_DOMAIN=chat.gatelm.co.kr
GATELM_CHAT_WEB_ORIGIN=https://chat.gatelm.co.kr

# Safe rehearsal overrides. They intentionally shadow values in the protected base env.
GATELM_DEMO_PROVIDER_MODE=mock
GATEWAY_DEFAULT_PROVIDER=mock
GATEWAY_DEFAULT_MODEL=mock-balanced
GATEWAY_LOW_COST_MODEL=mock-fast
GATEWAY_HIGH_QUALITY_MODEL=mock-smart
MOCK_PROVIDER_DEFAULT_LATENCY_MS=100
OPENAI_API_KEY=
CONTROL_PLANE_PROVIDER_CREDENTIAL_ENV_MAP=
GATEWAY_PROVIDER_CREDENTIAL_ENV_MAP=
AUTH_EMAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1
SMTP_SECURE=false
SMTP_TLS_MODE=opportunistic
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=clone-disabled@gatelm.invalid
