# Non-secret topology overlay for the five-host production environment.
# Keep protected production values separately in .env.production-distributed.base.
# Copy this file to .env.production-distributed and chmod both files to 600.

# Initial migration must use the exact SHA currently deployed to production.
GATELM_PRODUCTION_DISTRIBUTED_SOURCE_SHA=9936521039a6ace9d3ed32508c1fc92e89da61e2
GATELM_PRODUCTION_DISTRIBUTED_DB_SOURCE_SHA=9936521039a6ace9d3ed32508c1fc92e89da61e2
GATELM_PRODUCTION_DISTRIBUTED_IMAGE_TAG=993652103
GATELM_PRODUCTION_DISTRIBUTED_BUILD_CONTEXT=/home/ubuntu/GateLM
GATELM_PRODUCTION_DISTRIBUTED_E5_BUNDLE_CONTEXT=/home/ubuntu/GateLM/.tmp/gateway-e5-runtime-bundle

GATELM_PRODUCTION_DISTRIBUTED_EDGE_PRIVATE_IP=10.78.1.10
GATELM_PRODUCTION_DISTRIBUTED_GATEWAY_PRIVATE_IP=10.78.2.20
GATELM_PRODUCTION_DISTRIBUTED_DATA_PRIVATE_IP=10.78.2.30
GATELM_PRODUCTION_DISTRIBUTED_AI_PRIVATE_IP=10.78.2.40
GATELM_PRODUCTION_DISTRIBUTED_PII_PRIVATE_IP=10.78.2.50
GATELM_PRODUCTION_DISTRIBUTED_PII_MODEL_DIR=/opt/gatelm/pii-v36/releases/171bbde0/model
GATELM_PRODUCTION_DISTRIBUTED_PII_ARTIFACT_S3_URI=s3://gatelm-production-pii-artifacts-000000000000-ap-northeast-2/pii/v36/171bbde0/model.tar.gz
GATELM_PRODUCTION_DISTRIBUTED_PII_ARTIFACT_SHA256=8376070112e778ce1a7c4c5f29f8bcc78c482deb925fbaf7f0a9d9e1ef0a71a6

GATELM_PRODUCTION_DISTRIBUTED_SECRET_ROOT=/home/ubuntu/gatelm-production-secrets
GATELM_PRODUCTION_DISTRIBUTED_POSTGRES_VOLUME_NAME=gatelm-production-distributed-993652103-postgres-data
GATELM_PRODUCTION_DISTRIBUTED_REDIS_VOLUME_NAME=gatelm-production-distributed-993652103-redis-data
GATELM_PRODUCTION_DISTRIBUTED_CADDY_DATA_VOLUME_NAME=gatelm-production-distributed-993652103-caddy-data
GATELM_PRODUCTION_DISTRIBUTED_CADDY_CONFIG_VOLUME_NAME=gatelm-production-distributed-993652103-caddy-config

# Rehearsal uses an internal Caddy certificate and receives no DNS traffic.
# Change to production only during the final, explicitly approved cutover.
GATELM_PRODUCTION_DISTRIBUTED_PHASE=rehearsal
GATELM_PRODUCTION_DISTRIBUTED_LIVE_REQUESTS_ALLOWED=false
GATELM_PRODUCTION_DISTRIBUTED_CADDYFILE=./Caddyfile.production-distributed.rehearsal

GATELM_PUBLIC_DOMAIN=gatelm.co.kr
GATELM_PUBLIC_BASE_URL=https://gatelm.co.kr
GATELM_CHAT_DOMAIN=chat.gatelm.co.kr
GATELM_CHAT_WEB_ORIGIN=https://chat.gatelm.co.kr
