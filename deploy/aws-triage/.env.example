# GateLM AWS triage deployment settings.
# Copy this file to .env on the EC2 instance and replace every replace-me value.

# Public EC2 settings. Use the bare Public IPv4/DNS for GATELM_PUBLIC_DOMAIN.
GATELM_PUBLIC_DOMAIN=replace-me-ec2-public-ip
GATELM_PUBLIC_BASE_URL=http://replace-me-ec2-public-ip:3000
GATELM_CHAT_WEB_ORIGIN=http://replace-me-ec2-public-ip:3002

# Host port bindings. Keep Web/Chat Web public only for the first HTTP triage pass.
# Control Plane and Gateway bind to localhost by default and should not be opened publicly.
AWS_TRIAGE_WEB_BIND=0.0.0.0
AWS_TRIAGE_WEB_PORT=3000
AWS_TRIAGE_CHAT_WEB_BIND=0.0.0.0
AWS_TRIAGE_CHAT_WEB_PORT=3002
AWS_TRIAGE_CONTROL_PLANE_BIND=127.0.0.1
AWS_TRIAGE_CONTROL_PLANE_PORT=3001
AWS_TRIAGE_GATEWAY_BIND=127.0.0.1
AWS_TRIAGE_GATEWAY_PORT=8080

# PostgreSQL settings. Use hex/base64-like values; special URL characters can break DATABASE_URL interpolation.
POSTGRES_USER=gatelm
POSTGRES_PASSWORD=replace-me-postgres-password
POSTGRES_DB=gatelm

# Control Plane settings.
CONTROL_PLANE_ADMIN_AUTH_MODE=session_cookie
CONTROL_PLANE_AUTH_COOKIE_SECURE=false
CONTROL_PLANE_AUTH_STATE_SECRET=replace-me-with-random-value
CONTROL_PLANE_INTERNAL_SERVICE_TOKEN=replace-me-with-random-internal-service-token
TENANT_CHAT_PROJECTOR_ENABLED=false
TENANT_CHAT_PROJECTOR_INTERVAL_MS=1000
TENANT_CHAT_PROJECTOR_BATCH_SIZE=50
TENANT_CHAT_PROJECTOR_MAX_ATTEMPTS=5
TENANT_CHAT_RAG_ENABLED=false
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=1536
RAG_EMBEDDING_PROFILE_VERSION=1
RAG_DISTANCE_METRIC=cosine
RAG_OBJECT_STORE_DRIVER=s3
RAG_MAX_UPLOAD_BYTES=20971520
RAG_S3_REGION=ap-northeast-2
RAG_S3_BUCKET=replace-me-private-rag-bucket
RAG_S3_KMS_KEY_ID=replace-me-rag-kms-key-arn
RAG_EMBEDDING_CREDENTIAL_REF_ID=credential_ref_openai_main
RAG_EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
RAG_QUERY_EMBEDDING_ACTIVE_KID=replace-me-rag-query-kid
RAG_WORKER_EMBEDDING_ACTIVE_KID=replace-me-rag-worker-kid
RAG_WORKER_POLL_INTERVAL_MS=1000
RAG_WORKER_LEASE_DURATION_MS=120000
RAG_WORKER_RETRY_BASE_MS=1000
RAG_WORKER_RETRY_CAP_MS=300000
RAG_WORKER_EMBEDDING_BATCH_SIZE=64
DASHBOARD_ROLLUP_ENABLED=false
DASHBOARD_ROLLUP_INTERVAL_MS=1000
DASHBOARD_ROLLUP_DISCOVERY_BATCH_SIZE=500
DASHBOARD_ROLLUP_BUCKET_BATCH_SIZE=8
DASHBOARD_ROLLUP_DISCOVERY_LAG_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_INTERVAL_MS=60000
DASHBOARD_ROLLUP_RECONCILIATION_LOOKBACK_MS=900000
TENANT_CHAT_CONTROL_PLANE_SERVICE_TOKEN=replace-me-with-random-chat-control-plane-service-token
TENANT_CHAT_WEB_SERVICE_TOKEN=replace-me-with-random-chat-web-service-token
TENANT_CHAT_CACHE_KEY_SET_ID=tenant_chat_cache_keys_v1
TENANT_CHAT_ACCESS_JWT_SECRET=replace-me-with-random-chat-access-signing-secret
TENANT_CHAT_INTENT_SECRET=replace-me-with-random-chat-invitation-intent-secret
TENANT_CHAT_DB_POOL_LIMIT=12
TENANT_CHAT_WORKLOAD_ACTIVE_KID=replace-me-tenant-chat-workload-kid
TENANT_CHAT_RUNTIME_UID=1000
TENANT_CHAT_RUNTIME_GID=1000
AUTH_EMAIL_TRANSPORT=smtp
CONTROL_PLANE_AUTH_DEV_AUTO_VERIFY=false

# SMTP is required for AWS/prod-like auth. Do not use dev_memory or auto verify.
SMTP_HOST=replace-me-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_MODE=opportunistic
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=replace-me-sender@example.com

# Optional Google OAuth for the Web Console landing/login flow.
# Leave blank until a Google Cloud OAuth client is configured for this exact redirect URI.
# Set CONTROL_PLANE_AUTH_COOKIE_SECURE=true when this stack is served through HTTPS.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://replace-me-ec2-public-ip:3000/api/auth/google/callback
TENANT_CHAT_GOOGLE_REDIRECT_URI=http://replace-me-ec2-public-ip:3002/auth/google/callback

# Gateway runtime settings.
GATEWAY_RUNTIME_SNAPSHOT_MODE=strict
GATEWAY_CONTROL_PLANE_INTERNAL_TOKEN=replace-me-with-random-internal-service-token
GATEWAY_OBSERVABILITY_INTERNAL_TOKEN=replace-me-with-separate-random-observability-token
GATEWAY_CONTROL_PLANE_TIMEOUT_MS=2000
GATEWAY_DIFFICULTY_E5_RUNTIME_TIMEOUT_MS=100
GATELM_ROUTING_DIFFICULTY_SERVICE_TOKEN_PARAMETER_NAME=/gatelm/production/routing-difficulty-service-token
GATEWAY_DIFFICULTY_REMOTE_SERVICE_TOKEN=hydrated-at-deploy-time
GATEWAY_DIFFICULTY_REMOTE_TIMEOUT_MS=250
GATEWAY_DIFFICULTY_REMOTE_MAX_CONCURRENT=64

# Optional isolated LightGBM shadow. This never changes the LR route decision.
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_ENABLED=false
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_ALLOWED_SCOPES=
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_SAMPLING_BASIS_POINTS=1000
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_SERVICE_TOKEN=hydrated-at-deploy-time
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_MODEL_VERSION=
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_MODEL_CONTENT_HASH=
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_TIMEOUT_MS=500
GATEWAY_DIFFICULTY_LIGHTGBM_SHADOW_MAX_CONCURRENT=4
AI_SERVICE_ROUTING_LIGHTGBM_SHADOW_PROFILE_MANIFEST_SHA256=
AI_SERVICE_ROUTING_LIGHTGBM_SHADOW_MAX_CONCURRENT=4
AI_SERVICE_ROUTING_LIGHTGBM_SHADOW_WORKER_COUNT=1
AI_SERVICE_ROUTING_LIGHTGBM_SHADOW_ONNX_INTRA_OP_THREADS=1
AI_SERVICE_ROUTING_LIGHTGBM_SHADOW_ONNX_INTER_OP_THREADS=1
AI_SERVICE_LIGHTGBM_SHADOW_MEMORY_LIMIT=4g
AI_SERVICE_LIGHTGBM_SHADOW_PIDS_LIMIT=256
GATELM_LIGHTGBM_SHADOW_ARTIFACT_ROOT=
GATEWAY_PROVIDER_TIMEOUT_MS=60000
GATEWAY_DEFAULT_PROVIDER=mock
GATEWAY_DEFAULT_MODEL=mock-balanced
GATEWAY_LOW_COST_MODEL=mock-fast
GATEWAY_HIGH_QUALITY_MODEL=mock-smart
GATEWAY_EXACT_CACHE_KEY_SECRET=replace-me-cache-key-secret
GATEWAY_AUTH_CACHE_ENABLED=true
GATEWAY_AUTH_CACHE_TTL_MS=5000
GATEWAY_AUTH_CACHE_MAX_ENTRIES=4096
GATEWAY_MAX_REQUEST_BODY_BYTES=4194304
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_BACKEND=redis
GATEWAY_RATE_LIMIT_ALGORITHM=token_bucket
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_RATE_LIMIT_LIMIT=60
GATEWAY_RATE_LIMIT_REDIS_KEY_PREFIX=
GATEWAY_AI_SAFETY_SIDECAR_ENABLED=false

# Provider mode. Keep mock for the first AWS triage pass.
GATELM_DEMO_PROVIDER_MODE=mock
MOCK_PROVIDER_DEFAULT_LATENCY_MS=100

# Optional live provider bridge. Leave empty for mock mode.
GATELM_PROVIDER_CREDENTIAL_ENCRYPTION_KEY=
GATELM_PROVIDER_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1
CONTROL_PLANE_PROVIDER_CREDENTIAL_ENV_MAP=
GATEWAY_PROVIDER_CREDENTIAL_ENV_MAP=
OPENAI_API_KEY=

# Demo bootstrap values are disabled in AWS/prod-like environments by the seed guard.
# Keep the demo UUID values unchanged only for non-prod local seed experiments.
GATELM_DEMO_API_KEY=replace-me-demo-gateway-api-key
GATELM_DEMO_APP_TOKEN=replace-me-demo-app-token
GATELM_DEMO_TENANT_ID=00000000-0000-4000-8000-000000000100
GATELM_DEMO_PROJECT_ID=00000000-0000-4000-8000-000000000200
GATELM_DEMO_APPLICATION_ID=00000000-0000-4000-8000-000000000300
GATELM_DEMO_API_KEY_ID=00000000-0000-4000-8000-000000000400
GATELM_DEMO_APP_TOKEN_ID=00000000-0000-4000-8000-000000000500

# Web Console settings.
GATELM_WEB_RATE_LIMIT_MAX_ATTEMPTS=60
GATELM_GATEWAY_API_KEY=replace-me-runtime-project-gateway-api-key
GATELM_CONTROL_PLANE_TENANT_ID=
GATELM_CONTROL_PLANE_PROJECT_ID=
GATELM_CONTROL_PLANE_APPLICATION_ID=

# AI Service settings. Production distributed routing builds the CPU-only routing extra.
AI_SERVICE_INSTALL_ML_DEPS=true
AI_SERVICE_LOG_LEVEL=INFO
AI_SERVICE_REMOTE_SAFETY_MODE=disabled
AI_SERVICE_ACCESS_LOG_ENABLED=false
AI_SERVICE_TRANSFORMERS_OFFLINE=1
AI_SERVICE_AI_SAFETY_DETECTOR_RUNTIME=onnx
AI_SERVICE_AI_SAFETY_DETECTOR_MODEL_ID=openai/privacy-filter
AI_SERVICE_AI_SAFETY_ADDITIONAL_DETECTOR_MODEL_IDS=
AI_SERVICE_RAG_SERVICE_TOKEN=replace-me-with-a-random-32-character-token
AI_SERVICE_RAG_MAX_INPUT_BYTES=20971520
AI_SERVICE_RAG_MAX_PDF_PAGES=300
AI_SERVICE_RAG_MAX_EXTRACTED_CHARS=2000000
AI_SERVICE_RAG_PDF_PARSE_TIMEOUT_SECONDS=30
AI_SERVICE_RAG_MIN_PDF_TEXT_CHARS=20
AI_SERVICE_RAG_MAX_CHUNKS=10000
AI_SERVICE_RAG_CHUNK_TARGET_TOKENS=600
AI_SERVICE_RAG_CHUNK_OVERLAP_TOKENS=100
AI_SERVICE_RAG_CHUNK_MAX_TOKENS=900
AI_SERVICE_RAG_MAX_CONCURRENT_EXTRACTIONS=2
AI_SERVICE_ROUTING_DIFFICULTY_MAX_CONCURRENT=16
AI_SERVICE_ROUTING_DIFFICULTY_WORKER_COUNT=4
AI_SERVICE_ROUTING_DIFFICULTY_BATCH_SIZE=1
AI_SERVICE_ROUTING_DIFFICULTY_BATCH_MAX_WAIT_MS=0
AI_SERVICE_ROUTING_DIFFICULTY_ONNX_INTRA_OP_THREADS=1
AI_SERVICE_ROUTING_DIFFICULTY_ONNX_INTER_OP_THREADS=1
AI_SERVICE_CPU_LIMIT=4.0
AI_SERVICE_MEMORY_LIMIT=3g
AI_SERVICE_PIDS_LIMIT=256
AI_SERVICE_RAG_PDF_MEMORY_LIMIT_BYTES=536870912
AI_SERVICE_RAG_PDF_CPU_LIMIT_SECONDS=30
AI_SERVICE_RAG_TMPFS_SIZE=64m
AI_SERVICE_MEMORY_LIMIT=2g
AI_SERVICE_PIDS_LIMIT=128
